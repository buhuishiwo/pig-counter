{"ast":null,"code":"export default {\n  name: 'LogPanel',\n  computed: {\n    logs() {\n      return this.$store.getters.recentLogs;\n    }\n  },\n  methods: {\n    clearLogs() {\n      this.$store.commit('CLEAR_LOGS');\n    }\n  }\n};","map":{"version":3,"names":["name","computed","logs","$store","getters","recentLogs","methods","clearLogs","commit"],"sources":["src/components/LogPanel.vue"],"sourcesContent":["<template>\n  <div class=\"log-panel\">\n    <div class=\"panel-header\">\n      <span class=\"header-dot\"></span>\n      <span class=\"header-title\">系统日志</span>\n      <button class=\"btn-clear\" @click=\"clearLogs\" title=\"清空日志\">✕</button>\n    </div>\n    <div class=\"log-body\" ref=\"logBody\">\n      <div v-if=\"logs.length === 0\" class=\"log-empty\">等待操作...</div>\n      <transition-group name=\"log-slide\" tag=\"div\">\n        <div\n          v-for=\"log in logs\"\n          :key=\"log.id\"\n          class=\"log-line\"\n        >\n          <span class=\"log-time\">{{ log.time }}</span>\n          <span class=\"log-dot\" :class=\"log.type\"></span>\n          <span class=\"log-msg\" :class=\"log.type\">{{ log.msg }}</span>\n        </div>\n      </transition-group>\n    </div>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'LogPanel',\n  computed: {\n    logs() { return this.$store.getters.recentLogs }\n  },\n  methods: {\n    clearLogs() {\n      this.$store.commit('CLEAR_LOGS')\n    }\n  }\n}\n</script>\n\n<style scoped>\n.log-panel {\n  background: var(--card);\n  border: 1.5px solid var(--border);\n  border-radius: var(--radius);\n  overflow: hidden;\n}\n\n.panel-header {\n  display: flex;\n  align-items: center;\n  gap: 10px;\n  padding: 14px 18px;\n  border-bottom: 1px solid var(--border);\n}\n\n.header-dot {\n  width: 8px;\n  height: 8px;\n  border-radius: 50%;\n  background: var(--border);\n  flex-shrink: 0;\n}\n\n.header-title {\n  font-size: 20px;\n  letter-spacing: 0.12em;\n  text-transform: uppercase;\n  color: var(--text-muted);\n  font-weight: 700;\n  flex: 1;\n}\n\n.btn-clear {\n  background: none;\n  border: none;\n  color: var(--border);\n  cursor: pointer;\n  font-size: 11px;\n  padding: 2px 6px;\n  border-radius: 4px;\n  transition: color 0.15s, background 0.15s;\n  font-family: inherit;\n}\n\n.btn-clear:hover {\n  color: #e87070;\n  background: rgba(232, 112, 112, 0.08);\n}\n\n.log-body {\n  padding: 12px 16px;\n  max-height: 180px;\n  overflow-y: auto;\n  scrollbar-width: thin;\n  scrollbar-color: var(--border) transparent;\n}\n\n.log-body::-webkit-scrollbar { width: 4px; }\n.log-body::-webkit-scrollbar-track { background: transparent; }\n.log-body::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }\n\n.log-empty {\n  font-size: 11px;\n  color: var(--border);\n  padding: 8px 0;\n  letter-spacing: 0.05em;\n}\n\n.log-line {\n  display: flex;\n  align-items: flex-start;\n  gap: 8px;\n  padding: 3px 0;\n  font-size: 11px;\n  font-family: 'Space Mono', monospace;\n}\n\n.log-time {\n  color: var(--border);\n  flex-shrink: 0;\n  font-size: 10px;\n  padding-top: 1px;\n  letter-spacing: 0.02em;\n}\n\n.log-dot {\n  width: 5px;\n  height: 5px;\n  border-radius: 50%;\n  flex-shrink: 0;\n  margin-top: 4px;\n}\n\n.log-dot.info    { background: var(--accent); }\n.log-dot.success { background: var(--success); }\n.log-dot.error   { background: #e87070; }\n.log-dot.warn    { background: var(--accent2); }\n\n.log-msg {\n  line-height: 1.5;\n  word-break: break-all;\n}\n.log-msg.info    { color: var(--text-muted); }\n.log-msg.success { color: var(--success); }\n.log-msg.error   { color: #e87070; }\n.log-msg.warn    { color: var(--accent2); }\n\n/* Transition */\n.log-slide-enter-active { transition: all 0.25s ease; }\n.log-slide-enter        { opacity: 0; transform: translateY(-8px); }\n</style>\n"],"mappings":"AAyBA;EACAA,IAAA;EACAC,QAAA;IACAC,KAAA;MAAA,YAAAC,MAAA,CAAAC,OAAA,CAAAC,UAAA;IAAA;EACA;EACAC,OAAA;IACAC,UAAA;MACA,KAAAJ,MAAA,CAAAK,MAAA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}