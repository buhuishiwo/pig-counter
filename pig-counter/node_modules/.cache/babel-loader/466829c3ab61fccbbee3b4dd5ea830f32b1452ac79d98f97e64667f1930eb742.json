{"ast":null,"code":"import \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.for-each.js\";\nexport default {\n  name: 'BatchAnalyzeButton',\n  computed: {\n    hasBatchFiles() {\n      return this.$store.getters.hasBatchFiles;\n    },\n    isBatchAnalyzing() {\n      return this.$store.state.isBatchAnalyzing;\n    },\n    serviceOnline() {\n      return this.$store.state.serviceOnline === true;\n    }\n  },\n  methods: {\n    async analyzeBatch() {\n      if (!this.hasBatchFiles || !this.serviceOnline || this.isBatchAnalyzing) return;\n      this.$store.commit('SET_BATCH_ANALYZING', true);\n      this.$store.commit('ADD_LOG', {\n        msg: '开始批量分析...',\n        type: 'info'\n      });\n      try {\n        const files = this.$store.state.batchFiles;\n        const formData = new FormData();\n\n        // 添加文件\n        files.forEach(file => {\n          formData.append('files', file);\n        });\n\n        // 添加其他参数\n        formData.append('conf_threshold', 0.25);\n        formData.append('iou_threshold', 0.45);\n        formData.append('imgsz', 960);\n        const response = await fetch('/api/batch-predict', {\n          method: 'POST',\n          body: formData\n        });\n        if (!response.ok) {\n          const errorData = await response.json();\n          throw new Error(errorData.detail || '分析失败');\n        }\n        const result = await response.json();\n        this.$store.commit('SET_BATCH_RESULTS', result);\n        this.$store.commit('ADD_LOG', {\n          msg: `批量分析完成：${result.total_images} 张图片，共识别 ${result.total_pigs} 头猪`,\n          type: 'success'\n        });\n\n        // 显示成功提示\n        this.$emit('batchAnalyzed', result);\n      } catch (error) {\n        this.$store.commit('ADD_LOG', {\n          msg: `批量分析失败：${error.message}`,\n          type: 'error'\n        });\n      } finally {\n        this.$store.commit('SET_BATCH_ANALYZING', false);\n      }\n    }\n  }\n};","map":{"version":3,"names":["name","computed","hasBatchFiles","$store","getters","isBatchAnalyzing","state","serviceOnline","methods","analyzeBatch","commit","msg","type","files","batchFiles","formData","FormData","forEach","file","append","response","fetch","method","body","ok","errorData","json","Error","detail","result","total_images","total_pigs","$emit","error","message"],"sources":["src/components/BatchAnalyzeButton.vue"],"sourcesContent":["<template>\n  <div class=\"batch-analyze-button\">\n    <button\n      class=\"analyze-btn\"\n      :class=\"{ 'loading': isBatchAnalyzing, 'disabled': !hasBatchFiles || !serviceOnline || !selectedFarmId }\"\n      @click=\"analyzeBatch\"\n      :disabled=\"!hasBatchFiles || !serviceOnline || !selectedFarmId || isBatchAnalyzing\"\n    >\n      <span v-if=\"isBatchAnalyzing\" class=\"loading-spinner\"></span>\n      <span v-else class=\"btn-icon\">🐷</span>\n      <span class=\"btn-text\">\n        {{ isBatchAnalyzing ? '分析中...' : '批量分析' }}\n      </span>\n    </button>\n    <div v-if=\"!serviceOnline\" class=\"status-hint\">\n      服务离线，无法分析\n    </div>\n    <div v-else-if=\"!hasBatchFiles\" class=\"status-hint\">\n      请先上传图片\n    </div>\n    <div v-else-if=\"!selectedFarmId\" class=\"status-hint\">\n      请先选择猪场\n    </div>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'BatchAnalyzeButton',\n  computed: {\n    hasBatchFiles() { return this.$store.getters.hasBatchFiles },\n    isBatchAnalyzing() { return this.$store.state.isBatchAnalyzing },\n    serviceOnline() { return this.$store.state.serviceOnline === true }\n  },\n  methods: {\n    async analyzeBatch() {\n      if (!this.hasBatchFiles || !this.serviceOnline || this.isBatchAnalyzing) return\n\n      this.$store.commit('SET_BATCH_ANALYZING', true)\n      this.$store.commit('ADD_LOG', { msg: '开始批量分析...', type: 'info' })\n\n      try {\n        const files = this.$store.state.batchFiles\n        const formData = new FormData()\n\n        // 添加文件\n        files.forEach(file => {\n          formData.append('files', file)\n        })\n\n        // 添加其他参数\n        formData.append('conf_threshold', 0.25)\n        formData.append('iou_threshold', 0.45)\n        formData.append('imgsz', 960)\n\n        const response = await fetch('/api/batch-predict', {\n          method: 'POST',\n          body: formData\n        })\n\n        if (!response.ok) {\n          const errorData = await response.json()\n          throw new Error(errorData.detail || '分析失败')\n        }\n\n        const result = await response.json()\n        this.$store.commit('SET_BATCH_RESULTS', result)\n        this.$store.commit('ADD_LOG', {\n          msg: `批量分析完成：${result.total_images} 张图片，共识别 ${result.total_pigs} 头猪`,\n          type: 'success'\n        })\n\n        // 显示成功提示\n        this.$emit('batchAnalyzed', result)\n      } catch (error) {\n        this.$store.commit('ADD_LOG', { msg: `批量分析失败：${error.message}`, type: 'error' })\n      } finally {\n        this.$store.commit('SET_BATCH_ANALYZING', false)\n      }\n    }\n  }\n}\n</script>\n\n<style scoped>\n.batch-analyze-button {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 8px;\n}\n\n.analyze-btn {\n  display: flex;\n  align-items: center;\n  gap: 10px;\n  padding: 12px 24px;\n  background: linear-gradient(135deg, var(--pig-pink), #f28794);\n  color: white;\n  border: none;\n  border-radius: 12px;\n  font-size: 15px;\n  font-weight: 700;\n  cursor: pointer;\n  transition: all 0.2s;\n  box-shadow: 0 4px 12px rgba(242, 167, 176, 0.3);\n}\n\n.analyze-btn:hover:not(.disabled) {\n  transform: translateY(-2px);\n  box-shadow: 0 6px 16px rgba(242, 167, 176, 0.4);\n}\n\n.analyze-btn:active:not(.disabled) {\n  transform: translateY(0);\n}\n\n.analyze-btn.disabled {\n  background: var(--surface);\n  color: var(--text-muted);\n  border: 1px solid var(--border);\n  cursor: not-allowed;\n  box-shadow: none;\n}\n\n.analyze-btn.loading {\n  background: var(--pig-pink);\n  cursor: not-allowed;\n}\n\n.loading-spinner {\n  width: 16px;\n  height: 16px;\n  border: 2px solid rgba(255, 255, 255, 0.3);\n  border-top: 2px solid white;\n  border-radius: 50%;\n  animation: spin 1s linear infinite;\n}\n\n@keyframes spin {\n  0% { transform: rotate(0deg); }\n  100% { transform: rotate(360deg); }\n}\n\n.btn-icon {\n  font-size: 18px;\n}\n\n.status-hint {\n  font-size: 12px;\n  color: var(--text-muted);\n  text-align: center;\n}\n</style>"],"mappings":";;AA2BA;EACAA,IAAA;EACAC,QAAA;IACAC,cAAA;MAAA,YAAAC,MAAA,CAAAC,OAAA,CAAAF,aAAA;IAAA;IACAG,iBAAA;MAAA,YAAAF,MAAA,CAAAG,KAAA,CAAAD,gBAAA;IAAA;IACAE,cAAA;MAAA,YAAAJ,MAAA,CAAAG,KAAA,CAAAC,aAAA;IAAA;EACA;EACAC,OAAA;IACA,MAAAC,aAAA;MACA,UAAAP,aAAA,UAAAK,aAAA,SAAAF,gBAAA;MAEA,KAAAF,MAAA,CAAAO,MAAA;MACA,KAAAP,MAAA,CAAAO,MAAA;QAAAC,GAAA;QAAAC,IAAA;MAAA;MAEA;QACA,MAAAC,KAAA,QAAAV,MAAA,CAAAG,KAAA,CAAAQ,UAAA;QACA,MAAAC,QAAA,OAAAC,QAAA;;QAEA;QACAH,KAAA,CAAAI,OAAA,CAAAC,IAAA;UACAH,QAAA,CAAAI,MAAA,UAAAD,IAAA;QACA;;QAEA;QACAH,QAAA,CAAAI,MAAA;QACAJ,QAAA,CAAAI,MAAA;QACAJ,QAAA,CAAAI,MAAA;QAEA,MAAAC,QAAA,SAAAC,KAAA;UACAC,MAAA;UACAC,IAAA,EAAAR;QACA;QAEA,KAAAK,QAAA,CAAAI,EAAA;UACA,MAAAC,SAAA,SAAAL,QAAA,CAAAM,IAAA;UACA,UAAAC,KAAA,CAAAF,SAAA,CAAAG,MAAA;QACA;QAEA,MAAAC,MAAA,SAAAT,QAAA,CAAAM,IAAA;QACA,KAAAvB,MAAA,CAAAO,MAAA,sBAAAmB,MAAA;QACA,KAAA1B,MAAA,CAAAO,MAAA;UACAC,GAAA,YAAAkB,MAAA,CAAAC,YAAA,YAAAD,MAAA,CAAAE,UAAA;UACAnB,IAAA;QACA;;QAEA;QACA,KAAAoB,KAAA,kBAAAH,MAAA;MACA,SAAAI,KAAA;QACA,KAAA9B,MAAA,CAAAO,MAAA;UAAAC,GAAA,YAAAsB,KAAA,CAAAC,OAAA;UAAAtB,IAAA;QAAA;MACA;QACA,KAAAT,MAAA,CAAAO,MAAA;MACA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}