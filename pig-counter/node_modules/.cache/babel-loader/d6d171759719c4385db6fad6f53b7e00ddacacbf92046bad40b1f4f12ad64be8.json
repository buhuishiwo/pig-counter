{"ast":null,"code":"import \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.for-each.js\";\nimport LogPanel from '@/components/LogPanel.vue';\nimport ServiceStatus from '@/components/ServiceStatus.vue';\nimport { validateImage, fileToDataURL, getImageDimensions, formatFileSize } from '@/utils/imageUtils';\nimport { analyzeImageMock as analyzeImage, checkHealth } from '@/api/pigModel';\nexport default {\n  name: 'App',\n  components: {\n    LogPanel,\n    ServiceStatus\n  },\n  data() {\n    return {\n      checkingService: false,\n      isDragging: false,\n      hoveredBox: null,\n      animatedCount: 0\n    };\n  },\n  computed: {\n    hasImage() {\n      return this.$store.getters.hasImage;\n    },\n    hasResult() {\n      return this.$store.getters.hasResult;\n    },\n    previewUrl() {\n      return this.$store.state.previewUrl;\n    },\n    imageMeta() {\n      return this.$store.state.imageMeta;\n    },\n    isAnalyzing() {\n      return this.$store.state.isAnalyzing;\n    },\n    uploadProgress() {\n      return this.$store.state.uploadProgress;\n    },\n    result() {\n      return this.$store.state.result;\n    },\n    pigCount() {\n      return this.$store.getters.pigCount;\n    },\n    confidencePct() {\n      return this.$store.getters.confidencePct;\n    },\n    inferenceTime() {\n      return this.$store.getters.inferenceTime;\n    },\n    year() {\n      return new Date().getFullYear();\n    },\n    confClass() {\n      const p = this.confidencePct;\n      if (p >= 85) return 'conf-high';\n      if (p >= 65) return 'conf-mid';\n      return 'conf-low';\n    }\n  },\n  watch: {\n    pigCount(val) {\n      if (val === null) {\n        this.animatedCount = 0;\n        return;\n      }\n      this.animateNumber(val);\n    },\n    hasResult(val) {\n      if (val) this.$nextTick(() => this.drawBoxes());\n    }\n  },\n  created() {\n    this.checkServiceHealth();\n  },\n  methods: {\n    /* ---- File handling ---- */\n    onTopFileChange(e) {\n      const f = e.target.files[0];\n      if (f) this.processFile(f);\n      e.target.value = '';\n    },\n    onDropInputChange(e) {\n      const f = e.target.files[0];\n      if (f) this.processFile(f);\n      e.target.value = '';\n    },\n    onDrop(e) {\n      this.isDragging = false;\n      const f = e.dataTransfer.files[0];\n      if (f) this.processFile(f);\n    },\n    async processFile(file) {\n      const {\n        valid,\n        error\n      } = validateImage(file);\n      if (!valid) {\n        this.$store.commit('ADD_LOG', {\n          msg: error,\n          type: 'error'\n        });\n        return;\n      }\n      const dataURL = await fileToDataURL(file);\n      const dimensions = await getImageDimensions(dataURL);\n      const meta = {\n        name: file.name,\n        size: formatFileSize(file.size),\n        width: dimensions.width,\n        height: dimensions.height\n      };\n      this.$store.commit('SET_IMAGE', {\n        file,\n        previewUrl: dataURL,\n        meta\n      });\n      this.$store.commit('ADD_LOG', {\n        msg: `已加载：${file.name}（${meta.size}，${meta.width}×${meta.height}）`,\n        type: 'info'\n      });\n    },\n    clearImage() {\n      this.$store.commit('CLEAR_IMAGE');\n      this.$store.commit('ADD_LOG', {\n        msg: '已清除图片',\n        type: 'info'\n      });\n      this.clearCanvas();\n    },\n    /* ---- Analysis ---- */\n    async runAnalysis() {\n      if (!this.hasImage || this.isAnalyzing) return;\n      this.$store.commit('SET_ANALYZING', true);\n      this.$store.commit('SET_PROGRESS', 0);\n      this.$store.commit('ADD_LOG', {\n        msg: '发送至数猪大模型...',\n        type: 'info'\n      });\n      try {\n        const result = await analyzeImage(this.$store.state.imageFile, p => this.$store.commit('SET_PROGRESS', p));\n        this.$store.commit('SET_RESULT', result);\n        this.$store.commit('SET_PROGRESS', 100);\n        this.$store.commit('ADD_LOG', {\n          msg: `识别完成：检测到 ${result.count} 头猪`,\n          type: 'success'\n        });\n        this.$store.commit('ADD_LOG', {\n          msg: `置信度 ${Math.round(result.confidence * 100)}%` + (result.inferenceTime ? `  耗时 ${result.inferenceTime}ms` : ''),\n          type: 'success'\n        });\n      } catch (err) {\n        this.$store.commit('ADD_LOG', {\n          msg: `识别失败：${err.message}`,\n          type: 'error'\n        });\n      } finally {\n        this.$store.commit('SET_ANALYZING', false);\n      }\n    },\n    /* ---- Canvas bounding boxes ---- */\n    drawBoxes() {\n      const canvas = this.$refs.boxCanvas;\n      const img = this.$refs.baseImg;\n      if (!canvas || !img || !this.hasResult) return;\n      const boxes = this.result?.boxes || [];\n      canvas.width = img.clientWidth;\n      canvas.height = img.clientHeight;\n      const ctx = canvas.getContext('2d');\n      ctx.clearRect(0, 0, canvas.width, canvas.height);\n      const scaleX = canvas.width;\n      const scaleY = canvas.height;\n      boxes.forEach((box, i) => {\n        // box coords are 0~1 normalized OR pixel coords — handle both\n        const isNorm = box.x1 <= 1 && box.y1 <= 1;\n        const x1 = isNorm ? box.x1 * scaleX : box.x1 / (this.imageMeta?.width || 1) * scaleX;\n        const y1 = isNorm ? box.y1 * scaleY : box.y1 / (this.imageMeta?.height || 1) * scaleY;\n        const x2 = isNorm ? (box.x1 + box.x2) * scaleX : box.x2 / (this.imageMeta?.width || 1) * scaleX;\n        const y2 = isNorm ? (box.y1 + box.y2) * scaleY : box.y2 / (this.imageMeta?.height || 1) * scaleY;\n        const isHovered = this.hoveredBox === i;\n        ctx.strokeStyle = isHovered ? '#f4a24a' : '#39e879';\n        ctx.lineWidth = isHovered ? 2.5 : 1.5;\n        ctx.strokeRect(x1, y1, x2 - x1, y2 - y1);\n\n        // Label\n        const label = `${i + 1} ${(box.score * 100).toFixed(0)}%`;\n        ctx.font = 'bold 11px monospace';\n        const tw = ctx.measureText(label).width;\n        ctx.fillStyle = isHovered ? '#f4a24a' : '#39e879';\n        ctx.fillRect(x1, y1 - 18, tw + 8, 18);\n        ctx.fillStyle = '#000';\n        ctx.fillText(label, x1 + 4, y1 - 4);\n      });\n    },\n    clearCanvas() {\n      const canvas = this.$refs.boxCanvas;\n      if (canvas) canvas.getContext('2d').clearRect(0, 0, canvas.width, canvas.height);\n    },\n    /* ---- Helpers ---- */\n    animateNumber(target) {\n      const dur = 700,\n        start = Date.now(),\n        from = 0;\n      const tick = () => {\n        const t = Math.min((Date.now() - start) / dur, 1);\n        this.animatedCount = Math.round(from + (target - from) * (1 - Math.pow(1 - t, 3)));\n        if (t < 1) requestAnimationFrame(tick);\n      };\n      requestAnimationFrame(tick);\n    },\n    getConfClass(score) {\n      if (score >= 0.85) return 'conf-high';\n      if (score >= 0.65) return 'conf-mid';\n      return 'conf-low';\n    },\n    formatCoord(box) {\n      const isNorm = box.x1 <= 1 && box.y1 <= 1;\n      if (isNorm) {\n        const w = this.imageMeta?.width || 1;\n        const h = this.imageMeta?.height || 1;\n        return `${Math.round(box.x1 * w)}, ${Math.round(box.y1 * h)}, ${Math.round((box.x1 + box.x2) * w)}, ${Math.round((box.y1 + box.y2) * h)}`;\n      }\n      return `${Math.round(box.x1)}, ${Math.round(box.y1)}, ${Math.round(box.x2)}, ${Math.round(box.y2)}`;\n    },\n    async checkServiceHealth() {\n      this.checkingService = true;\n      this.$store.commit('ADD_LOG', {\n        msg: '检测模型服务状态...',\n        type: 'info'\n      });\n      try {\n        const online = await checkHealth();\n        this.$store.commit('SET_SERVICE_STATUS', online);\n        this.$store.commit('ADD_LOG', {\n          msg: online ? '模型服务在线' : '服务未响应（使用 Mock 模式）',\n          type: online ? 'success' : 'warn'\n        });\n      } catch {\n        this.$store.commit('SET_SERVICE_STATUS', false);\n      } finally {\n        this.checkingService = false;\n      }\n    }\n  }\n};","map":{"version":3,"names":["LogPanel","ServiceStatus","validateImage","fileToDataURL","getImageDimensions","formatFileSize","analyzeImageMock","analyzeImage","checkHealth","name","components","data","checkingService","isDragging","hoveredBox","animatedCount","computed","hasImage","$store","getters","hasResult","previewUrl","state","imageMeta","isAnalyzing","uploadProgress","result","pigCount","confidencePct","inferenceTime","year","Date","getFullYear","confClass","p","watch","val","animateNumber","$nextTick","drawBoxes","created","checkServiceHealth","methods","onTopFileChange","e","f","target","files","processFile","value","onDropInputChange","onDrop","dataTransfer","file","valid","error","commit","msg","type","dataURL","dimensions","meta","size","width","height","clearImage","clearCanvas","runAnalysis","imageFile","count","Math","round","confidence","err","message","canvas","$refs","boxCanvas","img","baseImg","boxes","clientWidth","clientHeight","ctx","getContext","clearRect","scaleX","scaleY","forEach","box","i","isNorm","x1","y1","x2","y2","isHovered","strokeStyle","lineWidth","strokeRect","label","score","toFixed","font","tw","measureText","fillStyle","fillRect","fillText","dur","start","now","from","tick","t","min","pow","requestAnimationFrame","getConfClass","formatCoord","w","h","online"],"sources":["src/App.vue"],"sourcesContent":["<template>\n  <div id=\"app\">\n    <div class=\"grain-overlay\" aria-hidden=\"true\"></div>\n\n    <!-- ===== TOP NAV BAR ===== -->\n    <nav class=\"topbar\">\n      <div class=\"topbar-inner\">\n        <div class=\"topbar-brand\">\n          <span class=\"brand-icon\">🐷</span>\n          <span class=\"brand-name\">PigVision AI</span>\n          <span class=\"brand-ver\">v1.0</span>\n        </div>\n        <ServiceStatus :checking=\"checkingService\" @check=\"checkServiceHealth\" />\n        <div class=\"topbar-actions\">\n          <label class=\"btn-upload-mini\" for=\"top-file-input\">\n            📁 上传图片\n          </label>\n          <input id=\"top-file-input\" type=\"file\" accept=\"image/jpeg,image/png,image/webp,image/bmp\" style=\"display:none\"\n            @change=\"onTopFileChange\" />\n          <button class=\"btn-analyze-mini\" :disabled=\"!hasImage || isAnalyzing\" @click=\"runAnalysis\">\n            <span v-if=\"isAnalyzing\" class=\"mini-spinner\"></span>\n            <span v-else>🔍</span>\n            {{ isAnalyzing ? '识别中...' : '开始识别' }}\n          </button>\n          <button v-if=\"hasImage\" class=\"btn-clear-mini\" @click=\"clearImage\">清除</button>\n        </div>\n      </div>\n      <!-- Progress bar under nav -->\n      <div class=\"topbar-progress\" v-if=\"isAnalyzing\">\n        <div class=\"topbar-progress-fill\" :style=\"{ width: uploadProgress + '%' }\"></div>\n      </div>\n    </nav>\n\n    <div class=\"page-wrap\">\n\n      <!-- ===== STAT CARDS ROW ===== -->\n      <div class=\"stat-row\">\n        <div class=\"stat-card\" :class=\"{ active: hasResult }\">\n          <div class=\"stat-icon\">🐷</div>\n          <div class=\"stat-val\">\n            <span v-if=\"hasResult\" class=\"stat-num animated\">{{ animatedCount }}</span>\n            <span v-else class=\"stat-num dim\">—</span>\n          </div>\n          <div class=\"stat-label\">预测数量</div>\n        </div>\n\n        <div class=\"stat-card\" :class=\"{ active: hasResult }\">\n          <div class=\"stat-icon\">⚡</div>\n          <div class=\"stat-val\">\n            <span v-if=\"inferenceTime\" class=\"stat-num\">{{ inferenceTime }}</span>\n            <span v-else class=\"stat-num dim\">—</span>\n            <span v-if=\"inferenceTime\" class=\"stat-unit\">ms</span>\n          </div>\n          <div class=\"stat-label\">处理耗时</div>\n        </div>\n\n        <div class=\"stat-card\" :class=\"{ active: hasResult }\">\n          <div class=\"stat-icon\">🎯</div>\n          <div class=\"stat-val\">\n            <span v-if=\"hasResult\" class=\"stat-num\" :class=\"confClass\">{{ confidencePct }}%</span>\n            <span v-else class=\"stat-num dim\">—</span>\n          </div>\n          <div class=\"stat-label\">平均置信度</div>\n        </div>\n\n        <div class=\"stat-card\" :class=\"{ active: imageMeta }\">\n          <div class=\"stat-icon\">📐</div>\n          <div class=\"stat-val\">\n            <span v-if=\"imageMeta\" class=\"stat-num sm\">{{ imageMeta.width }}×{{ imageMeta.height }}</span>\n            <span v-else class=\"stat-num dim\">—</span>\n          </div>\n          <div class=\"stat-label\">图像尺寸</div>\n        </div>\n      </div>\n\n      <!-- ===== DUAL IMAGE AREA ===== -->\n      <div class=\"image-row\">\n        <!-- Original image -->\n        <div class=\"img-card\">\n          <div class=\"img-card-header\">\n            <span class=\"img-card-dot\" style=\"background:var(--accent)\"></span>\n            <span class=\"img-card-title\">原图</span>\n            <span class=\"img-card-meta\" v-if=\"imageMeta\">{{ imageMeta.name }}</span>\n          </div>\n          <div class=\"img-card-body\">\n            <div class=\"img-dropzone\" :class=\"{ 'has-image': hasImage, 'drag-over': isDragging }\"\n              @dragover.prevent=\"isDragging = true\" @dragleave=\"isDragging = false\" @drop.prevent=\"onDrop\"\n              @click=\"!hasImage && $refs.dropInput.click()\">\n              <img v-if=\"hasImage\" :src=\"previewUrl\" class=\"img-preview\" alt=\"原图\" />\n              <div v-else class=\"img-placeholder\">\n                <div class=\"placeholder-pig\">🐷</div>\n                <p class=\"placeholder-title\">拖拽或点击上传猪群图片</p>\n                <p class=\"placeholder-sub\">JPG · PNG · WEBP · BMP &nbsp;|&nbsp; 最大 10MB</p>\n              </div>\n              <div v-if=\"isDragging\" class=\"drag-hint\">松开上传 🐽</div>\n              <input ref=\"dropInput\" type=\"file\" accept=\"image/*\" style=\"display:none\" @change=\"onDropInputChange\" />\n            </div>\n          </div>\n        </div>\n\n        <!-- Annotated result image -->\n        <div class=\"img-card\">\n          <div class=\"img-card-header\">\n            <span class=\"img-card-dot\" :style=\"{ background: hasResult ? 'var(--pig-pink)' : 'var(--border)' }\"></span>\n            <span class=\"img-card-title\">标注结果</span>\n            <span class=\"img-card-meta\" v-if=\"hasResult\">检测到 {{ pigCount }} 头猪</span>\n          </div>\n          <div class=\"img-card-body\">\n            <div class=\"img-result-zone\" :class=\"{ 'has-result': hasResult }\">\n              <!-- Canvas overlay with bounding boxes -->\n              <div class=\"canvas-wrap\" v-if=\"hasImage\">\n                <img :src=\"previewUrl\" class=\"img-preview\" alt=\"标注图\" ref=\"baseImg\" @load=\"drawBoxes\" />\n                <canvas ref=\"boxCanvas\" class=\"box-canvas\"></canvas>\n                <div v-if=\"!hasResult && !isAnalyzing\" class=\"result-waiting\">\n                  <span>等待识别...</span>\n                </div>\n                <div v-if=\"isAnalyzing\" class=\"result-loading\">\n                  <div class=\"result-spinner\"></div>\n                  <span>推理中</span>\n                </div>\n              </div>\n              <div v-else class=\"img-placeholder result-placeholder\">\n                <div class=\"placeholder-pig\" style=\"opacity:0.3\">🔍</div>\n                <p class=\"placeholder-title\" style=\"opacity:0.4\">识别结果将在此展示</p>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <!-- ===== DETECTION TABLE ===== -->\n      <div class=\"detail-section\" v-if=\"hasResult\">\n        <div class=\"detail-header\">\n          <div class=\"detail-title\">\n            <span class=\"detail-dot\"></span>\n            检测明细\n          </div>\n          <div class=\"detail-summary\">\n            共检测到 <strong>{{ pigCount }}</strong> 头猪 ·\n            平均置信度 <strong :class=\"confClass\">{{ confidencePct }}%</strong>\n          </div>\n        </div>\n\n        <div class=\"table-wrap\">\n          <table class=\"det-table\">\n            <thead>\n              <tr>\n                <th>#</th>\n                <th>类别</th>\n                <th>置信度</th>\n                <th>坐标</th>\n                <th>状态</th>\n              </tr>\n            </thead>\n            <tbody>\n              <tr v-for=\"(box, i) in result.boxes\" :key=\"i\" :class=\"{ 'row-highlight': hoveredBox === i }\"\n                @mouseenter=\"hoveredBox = i\" @mouseleave=\"hoveredBox = null\">\n                <td class=\"td-idx\">{{ i + 1 }}</td>\n                <td class=\"td-cls\">\n                  <span class=\"cls-tag\">pig</span>\n                </td>\n                <td class=\"td-conf\">\n                  <div class=\"conf-cell\">\n                    <div class=\"conf-mini-bar\">\n                      <div class=\"conf-mini-fill\" :class=\"getConfClass(box.score)\"\n                        :style=\"{ width: (box.score * 100) + '%' }\"></div>\n                    </div>\n                    <span :class=\"getConfClass(box.score)\">{{ (box.score * 100).toFixed(1) }}%</span>\n                  </div>\n                </td>\n                <td class=\"td-coord\">\n                  {{ formatCoord(box) }}\n                </td>\n                <td class=\"td-status\">\n                  <span class=\"status-ok\" v-if=\"box.score >= 0.7\">✓ 有效</span>\n                  <span class=\"status-warn\" v-else>△ 低置信</span>\n                </td>\n              </tr>\n            </tbody>\n          </table>\n        </div>\n      </div>\n\n      <!-- ===== LOG PANEL ===== -->\n      <LogPanel />\n\n      <footer class=\"footer\">\n        <span>PigVision AI · 智能数猪系统</span>\n        <span class=\"footer-sep\">|</span>\n        <span>Powered by 专属大模型 · © {{ year }}</span>\n      </footer>\n    </div>\n\n    <!-- Loading overlay -->\n    <transition name=\"fade\">\n      <div class=\"analysis-overlay\" v-if=\"isAnalyzing\">\n        <div class=\"analysis-modal\">\n          <div class=\"modal-spinner\"></div>\n          <div class=\"modal-title\">模型推理中</div>\n          <div class=\"modal-sub\">正在统计猪只数量，请稍候...</div>\n          <div class=\"modal-progress\">\n            <div class=\"modal-progress-fill\" :style=\"{ width: uploadProgress + '%' }\"></div>\n          </div>\n          <div class=\"modal-pct\">{{ uploadProgress }}%</div>\n        </div>\n      </div>\n    </transition>\n  </div>\n</template>\n\n<script>\nimport LogPanel from '@/components/LogPanel.vue'\nimport ServiceStatus from '@/components/ServiceStatus.vue'\nimport { validateImage, fileToDataURL, getImageDimensions, formatFileSize } from '@/utils/imageUtils'\nimport { analyzeImageMock as analyzeImage, checkHealth } from '@/api/pigModel'\n\nexport default {\n  name: 'App',\n  components: { LogPanel, ServiceStatus },\n\n  data() {\n    return {\n      checkingService: false,\n      isDragging: false,\n      hoveredBox: null,\n      animatedCount: 0\n    }\n  },\n\n  computed: {\n    hasImage() { return this.$store.getters.hasImage },\n    hasResult() { return this.$store.getters.hasResult },\n    previewUrl() { return this.$store.state.previewUrl },\n    imageMeta() { return this.$store.state.imageMeta },\n    isAnalyzing() { return this.$store.state.isAnalyzing },\n    uploadProgress() { return this.$store.state.uploadProgress },\n    result() { return this.$store.state.result },\n    pigCount() { return this.$store.getters.pigCount },\n    confidencePct() { return this.$store.getters.confidencePct },\n    inferenceTime() { return this.$store.getters.inferenceTime },\n    year() { return new Date().getFullYear() },\n    confClass() {\n      const p = this.confidencePct\n      if (p >= 85) return 'conf-high'\n      if (p >= 65) return 'conf-mid'\n      return 'conf-low'\n    }\n  },\n\n  watch: {\n    pigCount(val) {\n      if (val === null) { this.animatedCount = 0; return }\n      this.animateNumber(val)\n    },\n    hasResult(val) {\n      if (val) this.$nextTick(() => this.drawBoxes())\n    }\n  },\n\n  created() {\n    this.checkServiceHealth()\n  },\n\n  methods: {\n    /* ---- File handling ---- */\n    onTopFileChange(e) {\n      const f = e.target.files[0]\n      if (f) this.processFile(f)\n      e.target.value = ''\n    },\n    onDropInputChange(e) {\n      const f = e.target.files[0]\n      if (f) this.processFile(f)\n      e.target.value = ''\n    },\n    onDrop(e) {\n      this.isDragging = false\n      const f = e.dataTransfer.files[0]\n      if (f) this.processFile(f)\n    },\n    async processFile(file) {\n      const { valid, error } = validateImage(file)\n      if (!valid) {\n        this.$store.commit('ADD_LOG', { msg: error, type: 'error' })\n        return\n      }\n      const dataURL = await fileToDataURL(file)\n      const dimensions = await getImageDimensions(dataURL)\n      const meta = {\n        name: file.name,\n        size: formatFileSize(file.size),\n        width: dimensions.width,\n        height: dimensions.height\n      }\n      this.$store.commit('SET_IMAGE', { file, previewUrl: dataURL, meta })\n      this.$store.commit('ADD_LOG', {\n        msg: `已加载：${file.name}（${meta.size}，${meta.width}×${meta.height}）`,\n        type: 'info'\n      })\n    },\n    clearImage() {\n      this.$store.commit('CLEAR_IMAGE')\n      this.$store.commit('ADD_LOG', { msg: '已清除图片', type: 'info' })\n      this.clearCanvas()\n    },\n\n    /* ---- Analysis ---- */\n    async runAnalysis() {\n      if (!this.hasImage || this.isAnalyzing) return\n      this.$store.commit('SET_ANALYZING', true)\n      this.$store.commit('SET_PROGRESS', 0)\n      this.$store.commit('ADD_LOG', { msg: '发送至数猪大模型...', type: 'info' })\n      try {\n        const result = await analyzeImage(\n          this.$store.state.imageFile,\n          p => this.$store.commit('SET_PROGRESS', p)\n        )\n        this.$store.commit('SET_RESULT', result)\n        this.$store.commit('SET_PROGRESS', 100)\n        this.$store.commit('ADD_LOG', { msg: `识别完成：检测到 ${result.count} 头猪`, type: 'success' })\n        this.$store.commit('ADD_LOG', {\n          msg: `置信度 ${Math.round(result.confidence * 100)}%` +\n            (result.inferenceTime ? `  耗时 ${result.inferenceTime}ms` : ''),\n          type: 'success'\n        })\n      } catch (err) {\n        this.$store.commit('ADD_LOG', { msg: `识别失败：${err.message}`, type: 'error' })\n      } finally {\n        this.$store.commit('SET_ANALYZING', false)\n      }\n    },\n\n    /* ---- Canvas bounding boxes ---- */\n    drawBoxes() {\n      const canvas = this.$refs.boxCanvas\n      const img = this.$refs.baseImg\n      if (!canvas || !img || !this.hasResult) return\n\n      const boxes = this.result?.boxes || []\n      canvas.width = img.clientWidth\n      canvas.height = img.clientHeight\n      const ctx = canvas.getContext('2d')\n      ctx.clearRect(0, 0, canvas.width, canvas.height)\n\n      const scaleX = canvas.width\n      const scaleY = canvas.height\n\n      boxes.forEach((box, i) => {\n        // box coords are 0~1 normalized OR pixel coords — handle both\n        const isNorm = box.x1 <= 1 && box.y1 <= 1\n        const x1 = isNorm ? box.x1 * scaleX : box.x1 / (this.imageMeta?.width || 1) * scaleX\n        const y1 = isNorm ? box.y1 * scaleY : box.y1 / (this.imageMeta?.height || 1) * scaleY\n        const x2 = isNorm ? (box.x1 + box.x2) * scaleX : box.x2 / (this.imageMeta?.width || 1) * scaleX\n        const y2 = isNorm ? (box.y1 + box.y2) * scaleY : box.y2 / (this.imageMeta?.height || 1) * scaleY\n\n        const isHovered = this.hoveredBox === i\n        ctx.strokeStyle = isHovered ? '#f4a24a' : '#39e879'\n        ctx.lineWidth = isHovered ? 2.5 : 1.5\n        ctx.strokeRect(x1, y1, x2 - x1, y2 - y1)\n\n        // Label\n        const label = `${i + 1} ${(box.score * 100).toFixed(0)}%`\n        ctx.font = 'bold 11px monospace'\n        const tw = ctx.measureText(label).width\n        ctx.fillStyle = isHovered ? '#f4a24a' : '#39e879'\n        ctx.fillRect(x1, y1 - 18, tw + 8, 18)\n        ctx.fillStyle = '#000'\n        ctx.fillText(label, x1 + 4, y1 - 4)\n      })\n    },\n\n    clearCanvas() {\n      const canvas = this.$refs.boxCanvas\n      if (canvas) canvas.getContext('2d').clearRect(0, 0, canvas.width, canvas.height)\n    },\n\n    /* ---- Helpers ---- */\n    animateNumber(target) {\n      const dur = 700, start = Date.now(), from = 0\n      const tick = () => {\n        const t = Math.min((Date.now() - start) / dur, 1)\n        this.animatedCount = Math.round(from + (target - from) * (1 - Math.pow(1 - t, 3)))\n        if (t < 1) requestAnimationFrame(tick)\n      }\n      requestAnimationFrame(tick)\n    },\n\n    getConfClass(score) {\n      if (score >= 0.85) return 'conf-high'\n      if (score >= 0.65) return 'conf-mid'\n      return 'conf-low'\n    },\n\n    formatCoord(box) {\n      const isNorm = box.x1 <= 1 && box.y1 <= 1\n      if (isNorm) {\n        const w = this.imageMeta?.width || 1\n        const h = this.imageMeta?.height || 1\n        return `${Math.round(box.x1 * w)}, ${Math.round(box.y1 * h)}, ${Math.round((box.x1 + box.x2) * w)}, ${Math.round((box.y1 + box.y2) * h)}`\n      }\n      return `${Math.round(box.x1)}, ${Math.round(box.y1)}, ${Math.round(box.x2)}, ${Math.round(box.y2)}`\n    },\n\n    async checkServiceHealth() {\n      this.checkingService = true\n      this.$store.commit('ADD_LOG', { msg: '检测模型服务状态...', type: 'info' })\n      try {\n        const online = await checkHealth()\n        this.$store.commit('SET_SERVICE_STATUS', online)\n        this.$store.commit('ADD_LOG', {\n          msg: online ? '模型服务在线' : '服务未响应（使用 Mock 模式）',\n          type: online ? 'success' : 'warn'\n        })\n      } catch {\n        this.$store.commit('SET_SERVICE_STATUS', false)\n      } finally {\n        this.checkingService = false\n      }\n    }\n  }\n}\n</script>\n\n<style>\n:root {\n  /* ===== Apple-like Light System ===== */\n  --bg: #f5f6f8;\n  --surface: rgba(255, 255, 255, 0.65);\n  --card: rgba(255, 255, 255, 0.72);\n\n  --border: rgba(0, 0, 0, 0.06);\n  --border-strong: rgba(0, 0, 0, 0.12);\n\n  --text: #1d1d1f;\n  --text-muted: #8e8e93;\n\n  /* 去掉高饱和 */\n  --accent: #7a8cff;\n  --accent2: #a0a8ff;\n\n  --pig-pink: #ffb7c5;\n  --pig-pink-dim: #f2d5db;\n\n  --success: #34c759;\n\n  --radius: 16px;\n\n  /* 雾化核心 */\n  --blur: blur(20px);\n  --glass-shadow: 0 10px 30px rgba(0, 0, 0, 0.06);\n}\n\n*,\n*::before,\n*::after {\n  box-sizing: border-box;\n  margin: 0;\n  padding: 0;\n}\n\nhtml {\n  font-size: 16px;\n}\n\nbody {\n  background: linear-gradient(180deg, #f7f8fa 0%, #eef1f5 100%);\n  color: var(--text);\n  font-family: -apple-system, BlinkMacSystemFont, \"SF Pro Text\", sans-serif;\n}\n\n#app {\n  position: relative;\n  min-height: 100vh;\n}\n\n.grain-overlay {\n  position: fixed;\n  inset: 0;\n  pointer-events: none;\n  z-index: 9999;\n  opacity: 0.08;\n  background-image: url(\"data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.05'/%3E%3C/svg%3E\");\n}\n\n/* ============================================================ TOPBAR */\n.topbar {\n  position: sticky;\n  top: 0;\n  z-index: 100;\n  background: rgba(255, 255, 255, 0.6);\n  backdrop-filter: var(--blur);\n  border-bottom: 1px solid var(--border);\n}\n\n.topbar-inner {\n  max-width: 1400px;\n  margin: 0 auto;\n  padding: 0 24px;\n  height: 56px;\n  display: flex;\n  align-items: center;\n  gap: 16px;\n}\n\n.topbar-brand {\n  display: flex;\n  align-items: center;\n  gap: 8px;\n  margin-right: 8px;\n}\n\n.brand-icon {\n  font-size: 20px;\n}\n\n.brand-name {\n  font-family: 'Noto Serif SC', serif;\n  font-size: 16px;\n  font-weight: 900;\n  background: linear-gradient(135deg, var(--text), var(--pig-pink));\n  -webkit-background-clip: text;\n  -webkit-text-fill-color: transparent;\n  background-clip: text;\n}\n\n.brand-ver {\n  font-size: 10px;\n  color: var(--text-muted);\n  border: 1px solid var(--border);\n  border-radius: 3px;\n  padding: 1px 5px;\n  letter-spacing: 0.06em;\n}\n\n.topbar-actions {\n  margin-left: auto;\n  display: flex;\n  align-items: center;\n  gap: 10px;\n}\n\n.btn-upload-mini {\n  padding: 7px 14px;\n  background: rgba(0,0,0,0.02);\n  border: 1px solid var(--border);\n  border-radius: 7px;\n  font-family: 'Space Mono', monospace;\n  font-size: 12px;\n  color: var(--text);\n  cursor: pointer;\n  transition: all 0.15s;\n  white-space: nowrap;\n}\n\n.btn-upload-mini:hover {\n  background: rgba(0,0,0,0.04);\n  color: var(--text);\n}\n\n.btn-analyze-mini {\n  display: flex;\n  align-items: center;\n  gap: 7px;\n  padding: 7px 16px;\n  background: rgba(122,140,255,0.12);\n  color: var(--accent);\n  border: 1px solid rgba(122,140,255,0.2);\n  border-radius: 7px;\n  font-family: 'Space Mono', monospace;\n  font-size: 12px;\n  font-weight: 700;\n  cursor: pointer;\n  transition: all 0.15s;\n  white-space: nowrap;\n}\n\n.btn-analyze-mini:hover:not(:disabled) {\n  transform: translateY(-1px);\n  background: rgba(122,140,255,0.18);\n  box-shadow: none;\n}\n\n.btn-analyze-mini:disabled {\n  background: var(--surface);\n  color: var(--text-muted);\n  border: 1.5px solid var(--border);\n  cursor: not-allowed;\n}\n\n.mini-spinner {\n  width: 12px;\n  height: 12px;\n  border: 2px solid rgba(0, 0, 0, 0.2);\n  border-top-color: #000;\n  border-radius: 50%;\n  animation: spin 0.6s linear infinite;\n}\n\n.btn-clear-mini {\n  padding: 7px 12px;\n  background: none;\n  border: 1.5px solid var(--border);\n  border-radius: 7px;\n  font-family: 'Space Mono', monospace;\n  font-size: 12px;\n  color: var(--text-muted);\n  cursor: pointer;\n  transition: all 0.15s;\n}\n\n.btn-clear-mini:hover {\n  border-color: var(--pig-pink-dim);\n  color: var(--pig-pink);\n}\n\n.topbar-progress {\n  height: 2px;\n  background: var(--border);\n}\n\n.topbar-progress-fill {\n  height: 100%;\n  background: linear-gradient(90deg, var(--pig-pink), var(--accent));\n  transition: width 0.3s ease;\n}\n\n/* ============================================================ PAGE WRAP */\n.page-wrap {\n  max-width: 1400px;\n  margin: 0 auto;\n  padding: 28px 24px 80px;\n  display: flex;\n  flex-direction: column;\n  gap: 20px;\n}\n\n/* ============================================================ STAT ROW */\n.stat-row {\n  display: grid;\n  grid-template-columns: repeat(4, 1fr);\n  gap: 14px;\n}\n\n@media (max-width: 900px) {\n  .stat-row {\n    grid-template-columns: repeat(2, 1fr);\n  }\n}\n\n@media (max-width: 500px) {\n  .stat-row {\n    grid-template-columns: 1fr 1fr;\n  }\n}\n\n.stat-card {\n  background: var(--card);\n  border: 1px solid var(--border);\n  backdrop-filter: var(--blur);\n  border-radius: var(--radius);\n  box-shadow: var(--glass-shadow);\n  padding: 20px 22px;\n  transition: border-color 0.3s;\n  display: flex;\n  flex-direction: column;\n  gap: 6px;\n}\n\n.stat-card.active {\n  border-color: rgba(242, 167, 176, 0.3);\n}\n\n.stat-icon {\n  font-size: 22px;\n}\n\n.stat-val {\n  display: flex;\n  align-items: baseline;\n  gap: 4px;\n  min-height: 44px;\n  align-items: center;\n}\n\n.stat-num {\n  font-family: 'Noto Serif SC', serif;\n  font-size: 36px;\n  line-height: 1;\n  background: linear-gradient(135deg, var(--text), var(--pig-pink));\n  -webkit-background-clip: text;\n  background-clip: text;\n  background: none;\n  -webkit-text-fill-color: unset;\n  color: var(--text);\n  font-weight: 600;\n}\n.stat-num.conf-high { color: #34c759; }\n.stat-num.conf-mid  { color: #ff9f0a; }\n.stat-num.conf-low  { color: #ff3b30; }\n.stat-num.dim {\n  color: var(--border);\n  -webkit-text-fill-color: var(--border);\n  background: none;\n  font-size: 36px;\n}\n\n.stat-num.sm {\n  font-size: 22px;\n}\n\n.stat-num.conf-high {\n  background: linear-gradient(135deg, #39e879, #2ab85f);\n  -webkit-background-clip: text;\n  -webkit-text-fill-color: transparent;\n  background-clip: text;\n}\n\n.stat-num.conf-mid {\n  background: linear-gradient(135deg, var(--accent2), var(--accent));\n  -webkit-background-clip: text;\n  -webkit-text-fill-color: transparent;\n  background-clip: text;\n}\n\n.stat-num.conf-low {\n  background: linear-gradient(135deg, #e87070, #c04040);\n  -webkit-background-clip: text;\n  -webkit-text-fill-color: transparent;\n  background-clip: text;\n}\n\n.stat-unit {\n  font-size: 14px;\n  color: var(--text-muted);\n  -webkit-text-fill-color: var(--text-muted);\n}\n\n.stat-label {\n  font-size: 11px;\n  letter-spacing: 0.1em;\n  text-transform: uppercase;\n  color: var(--text-muted);\n}\n\n/* ============================================================ IMAGE ROW */\n.image-row {\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  gap: 16px;\n}\n\n@media (max-width: 700px) {\n  .image-row {\n    grid-template-columns: 1fr;\n  }\n}\n\n.img-card {\n  background: var(--card);\n  backdrop-filter: var(--blur);\n\n  border: 1px solid var(--border);\n  border-radius: var(--radius);\n\n  box-shadow: var(--glass-shadow);\n  overflow: hidden;\n}\n\n.img-card-header {\n  display: flex;\n  align-items: center;\n  gap: 10px;\n  padding: 13px 18px;\n  border-bottom: 1px solid var(--border);\n}\n\n.img-card-dot {\n  width: 8px;\n  height: 8px;\n  border-radius: 50%;\n  flex-shrink: 0;\n}\n\n.img-card-title {\n  font-size: 11px;\n  letter-spacing: 0.12em;\n  text-transform: uppercase;\n  color: var(--text-muted);\n  font-weight: 700;\n}\n\n.img-card-meta {\n  margin-left: auto;\n  font-size: 10px;\n  color: var(--text-muted);\n  background: var(--surface);\n  border: 1px solid var(--border);\n  border-radius: 4px;\n  padding: 2px 8px;\n  letter-spacing: 0.04em;\n  max-width: 180px;\n  overflow: hidden;\n  text-overflow: ellipsis;\n  white-space: nowrap;\n}\n\n.img-card-body {\n  padding: 16px;\n}\n\n/* Dropzone */\n.img-dropzone {\n  width: 100%;\n  aspect-ratio: 16/10;\n  border-radius: 10px;\n  position: relative;\n  overflow: hidden;\n  cursor: pointer;\n  transition: all 0.2s;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n.img-dropzone,\n.img-result-zone {\n  background: rgba(255,255,255,0.5);\n  backdrop-filter: var(--blur);\n\n  border: 1px solid var(--border);\n}\n.img-dropzone:hover:not(.has-image) {\n  border-color: var(--border-strong);\n  background: rgba(255,255,255,0.7);\n}\n\n.img-dropzone.drag-over {\n  border-color: var(--accent);\n  background: rgba(232, 200, 74, 0.06);\n}\n\n.img-dropzone.has-image {\n  border-style: solid;\n  border-color: var(--border);\n  cursor: default;\n}\n\n.img-preview {\n  width: 100%;\n  height: 100%;\n  object-fit: contain;\n  display: block;\n}\n\n.img-placeholder {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 12px;\n  padding: 24px;\n  text-align: center;\n}\n\n.result-placeholder {\n  opacity: 0.5;\n}\n\n.placeholder-pig {\n  font-size: 48px;\n  animation: float 3s ease-in-out infinite;\n}\n\n@keyframes float {\n\n  0%,\n  100% {\n    transform: translateY(0) rotate(-3deg);\n  }\n\n  50% {\n    transform: translateY(-8px) rotate(3deg);\n  }\n}\n\n.placeholder-title {\n  font-size: 14px;\n  color: var(--text);\n  font-weight: 700;\n}\n\n.placeholder-sub {\n  font-size: 11px;\n  color: var(--text-muted);\n}\n\n.drag-hint {\n  position: absolute;\n  inset: 0;\n  background: rgba(232, 200, 74, 0.12);\n  backdrop-filter: blur(3px);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  font-size: 16px;\n  font-weight: 700;\n  color: var(--accent);\n}\n\n/* Result zone */\n.img-result-zone {\n  width: 100%;\n  aspect-ratio: 16/10;\n  border-radius: 10px;\n  overflow: hidden;\n  position: relative;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n\n.img-result-zone.has-result {\n  border-color: rgba(57, 232, 121, 0.25);\n}\n\n.canvas-wrap {\n  width: 100%;\n  height: 100%;\n  position: relative;\n}\n\n.canvas-wrap .img-preview {\n  width: 100%;\n  height: 100%;\n  object-fit: contain;\n}\n\n.box-canvas {\n  position: absolute;\n  top: 0;\n  left: 0;\n  width: 100%;\n  height: 100%;\n  pointer-events: none;\n}\n\n.result-waiting,\n.result-loading {\n  position: absolute;\n  inset: 0;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  gap: 10px;\n  background: rgba(0, 0, 0, 0.45);\n  backdrop-filter: blur(3px);\n  font-size: 12px;\n  color: var(--text-muted);\n  letter-spacing: 0.08em;\n}\n\n.result-spinner {\n  width: 32px;\n  height: 32px;\n  border: 3px solid var(--border);\n  border-top-color: var(--accent);\n  border-radius: 50%;\n  animation: spin 0.7s linear infinite;\n}\n\n@keyframes spin {\n  to {\n    transform: rotate(360deg);\n  }\n}\n\n/* ============================================================ DETAIL TABLE */\n.detail-section {\n  background: var(--card);\n  backdrop-filter: var(--blur);\n\n  border: 1px solid var(--border);\n  border-radius: var(--radius);\n\n  box-shadow: var(--glass-shadow);\n  overflow: hidden;\n}\n\n.detail-header {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  padding: 14px 20px;\n  border-bottom: 1px solid var(--border);\n  flex-wrap: wrap;\n  gap: 8px;\n}\n\n.detail-title {\n  display: flex;\n  align-items: center;\n  gap: 10px;\n  font-size: 11px;\n  letter-spacing: 0.12em;\n  text-transform: uppercase;\n  color: var(--text-muted);\n  font-weight: 700;\n}\n\n.detail-dot {\n  width: 8px;\n  height: 8px;\n  border-radius: 50%;\n  background: var(--success);\n  box-shadow: 0 0 6px var(--success);\n}\n\n.detail-summary {\n  font-size: 12px;\n  color: var(--text-muted);\n}\n\n.detail-summary strong {\n  color: var(--text);\n}\n\n.detail-summary .conf-high {\n  color: var(--success);\n}\n\n.detail-summary .conf-mid {\n  color: var(--accent);\n}\n\n.detail-summary .conf-low {\n  color: #e87070;\n}\n\n.table-wrap {\n  overflow-x: auto;\n}\n\n.det-table {\n  width: 100%;\n  border-collapse: collapse;\n  font-size: 12px;\n}\n\n.det-table th {\n  padding: 10px 16px;\n  text-align: left;\n  font-size: 10px;\n  letter-spacing: 0.12em;\n  text-transform: uppercase;\n  color: var(--text-muted);\n  font-weight: 700;\n  border-bottom: 1px solid var(--border);\n  background: transparent;\n}\n\n.det-table td {\n  padding: 10px 16px;\n  border-bottom: 1px solid rgba(0,0,0,0.05);\n  transition: background 0.15s;\n}\n\n.det-table tr:last-child td {\n  border-bottom: none;\n}\n\n.row-highlight td {\n  background: rgba(242, 167, 176, 0.04);\n}\n\n.td-idx {\n  color: var(--text-muted);\n  width: 40px;\n}\n\n.cls-tag {\n  background: rgba(57, 232, 121, 0.1);\n  border: 1px solid rgba(57, 232, 121, 0.25);\n  color: var(--success);\n  border-radius: 4px;\n  padding: 2px 8px;\n  font-size: 11px;\n  letter-spacing: 0.04em;\n}\n\n.conf-cell {\n  display: flex;\n  align-items: center;\n  gap: 10px;\n}\n\n.conf-mini-bar {\n  width: 80px;\n  height: 4px;\n  background: var(--border);\n  border-radius: 2px;\n  overflow: hidden;\n}\n\n.conf-mini-fill {\n  height: 100%;\n  border-radius: 2px;\n  transition: width 0.4s ease;\n}\n\n.conf-mini-fill.conf-high {\n  background: var(--success);\n}\n\n.conf-mini-fill.conf-mid {\n  background: var(--accent);\n}\n\n.conf-mini-fill.conf-low {\n  background: #e87070;\n}\n\n.conf-high {\n  color: var(--success);\n}\n\n.conf-mid {\n  color: var(--accent);\n}\n\n.conf-low {\n  color: #e87070;\n}\n\n.td-coord {\n  color: var(--text-muted);\n  font-size: 11px;\n  letter-spacing: 0.02em;\n}\n\n.status-ok {\n  color: var(--success);\n  font-size: 11px;\n}\n\n.status-warn {\n  color: var(--accent2);\n  font-size: 11px;\n}\n\n/* ============================================================ FOOTER */\n.footer {\n  text-align: center;\n  font-size: 11px;\n  color: var(--border);\n  letter-spacing: 0.08em;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  gap: 10px;\n  margin-top: 12px;\n}\n\n.footer-sep {\n  opacity: 0.4;\n}\n\n/* ===========