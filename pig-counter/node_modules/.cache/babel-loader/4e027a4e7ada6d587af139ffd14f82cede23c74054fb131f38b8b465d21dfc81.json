{"ast":null,"code":"export default {\n  name: 'App'\n};","map":{"version":3,"names":["name"],"sources":["src/App.vue"],"sourcesContent":["<template>\n  <div id=\"app\">\n    <div class=\"ambient-wrap\" aria-hidden=\"true\">\n      <div class=\"ambient-orb orb-1\"></div>\n      <div class=\"ambient-orb orb-2\"></div>\n      <div class=\"ambient-orb orb-3\"></div>\n      <div class=\"ambient-grid\"></div>\n    </div>\n\n    <nav class=\"topbar\">\n      <div class=\"topbar-inner\">\n        <div class=\"topbar-brand\">\n          <div class=\"brand-logo\">\n            <span class=\"brand-emoji\">\n              <img src=\"/icon/icon-48x48.png\" alt=\"智慧猪群识别系统\" />\n            </span>\n            <div class=\"brand-glow\"></div>\n          </div>\n          <div class=\"brand-text\">\n            <span class=\"brand-name\">智慧猪群识别系统</span>\n            <span class=\"brand-tag\">AI</span>\n          </div>\n          <div class=\"brand-sep\"></div>\n          <span class=\"brand-sub\">v0.1</span>\n        </div>\n\n        <!-- 导航菜单 -->\n        <div class=\"nav-menu\">\n          <router-link to=\"/\" class=\"nav-link\">首页</router-link>\n          <router-link to=\"/stats\" class=\"nav-link\">统计数据</router-link>\n        </div>\n\n        <div class=\"service-pill service-online\">\n          <div class=\"service-dot\"></div>\n          <span>服务正常</span>\n        </div>\n      </div>\n    </nav>\n\n    <!-- 路由视图 -->\n    <router-view />\n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'App'\n}\n</script>\n\n<style>\n/* 导航菜单 */\n.nav-menu {\n  display: flex;\n  gap: 20px;\n  margin-left: 40px;\n}\n\n.nav-link {\n  color: #333;\n  text-decoration: none;\n  padding: 8px 16px;\n  border-radius: 4px;\n  transition: all 0.3s ease;\n  font-weight: 500;\n}\n\n.nav-link:hover {\n  background-color: rgba(0, 0, 0, 0.05);\n  color: #007bff;\n}\n\n.nav-link.router-link-active {\n  background-color: #007bff;\n  color: white;\n  box-shadow: 0 2px 4px rgba(0, 123, 255, 0.3);\n}\n\n:root {\n  --bg: #f2f2f7;\n  --bg-2: #ffffff;\n  --glass-bg: rgba(255, 255, 255, 0.65);\n  --glass-border: rgba(255, 255, 255, 0.8);\n  --glass-shadow: rgba(0, 0, 0, 0.05);\n  --text: #1c1c1e;\n  --text-2: #636366;\n  --text-3: #8e8e93;\n  --accent: #007bff;\n  --success: #34c759;\n  --warning: #ff9500;\n  --danger: #ff3b30;\n  --border: #e5e5ea;\n  --border-2: #c7c7cc;\n  --card-bg: rgba(255, 255, 255, 0.7);\n  --backdrop: rgba(0, 0, 0, 0.5);\n  --backdrop-light: rgba(0, 0, 0, 0.05);\n  --backdrop-blur: blur(20px);\n  --animate-duration: 300ms;\n  --animate-delay: 100ms;\n  --card-radius: 12px;\n  --btn-radius: 8px;\n  --orb-radius: 50%;\n  --pulse-duration: 3s;\n  --scan-duration: 2s;\n  --scan-delay: 600ms;\n  --scan-glow: 50px;\n}\n\n* {\n  margin: 0;\n  padding: 0;\n  box-sizing: border-box;\n  -webkit-font-smoothing: antialiased;\n  -moz-osx-font-smoothing: grayscale;\n}\n\nbody {\n  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;\n  font-size: 16px;\n  line-height: 1.5;\n  color: var(--text);\n  background-color: var(--bg);\n  overflow-x: hidden;\n  min-height: 100vh;\n}\n\n#app {\n  min-height: 100vh;\n  position: relative;\n}\n\n.ambient-wrap {\n  position: fixed;\n  top: 0;\n  left: 0;\n  width: 100vw;\n  height: 100vh;\n  overflow: hidden;\n  pointer-events: none;\n  z-index: -1;\n}\n\n.ambient-orb {\n  position: absolute;\n  border-radius: var(--orb-radius);\n  filter: blur(80px);\n  opacity: 0.3;\n  transition: transform 20s ease-in-out;\n  animation: float 30s ease-in-out infinite;\n}\n\n.orb-1 {\n  top: -10%;\n  left: -10%;\n  width: 400px;\n  height: 400px;\n  background: radial-gradient(circle, rgba(0,123,255,0.8) 0%, rgba(0,123,255,0) 70%);\n  animation-delay: -10s;\n}\n\n.orb-2 {\n  bottom: -10%;\n  right: -10%;\n  width: 350px;\n  height: 350px;\n  background: radial-gradient(circle, rgba(52,199,89,0.8) 0%, rgba(52,199,89,0) 70%);\n  animation-delay: -5s;\n}\n\n.orb-3 {\n  top: 50%;\n  right: 10%;\n  width: 250px;\n  height: 250px;\n  background: radial-gradient(circle, rgba(255,149,0,0.8) 0%, rgba(255,149,0,0) 70%);\n  animation-delay: 0s;\n}\n\n.ambient-grid {\n  position: absolute;\n  top: 0;\n  left: 0;\n  width: 100%;\n  height: 100%;\n  background-image: linear-gradient(rgba(0,0,0,0.03) 1px, transparent 1px),\n                    linear-gradient(90deg, rgba(0,0,0,0.03) 1px, transparent 1px);\n  background-size: 20px 20px;\n  opacity: 0.3;\n}\n\n.topbar {\n  position: sticky;\n  top: 0;\n  z-index: 1000;\n  background: var(--glass-bg);\n  backdrop-filter: var(--backdrop-blur);\n  border-bottom: 1px solid var(--glass-border);\n  box-shadow: 0 2px 10px var(--glass-shadow);\n  padding: 0 24px;\n}\n\n.topbar-inner {\n  max-width: 1400px;\n  margin: 0 auto;\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  height: 60px;\n}\n\n.topbar-brand {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n  font-size: 18px;\n  font-weight: 700;\n  color: var(--text);\n}\n\n.brand-logo {\n  position: relative;\n  width: 32px;\n  height: 32px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n\n.brand-emoji {\n  font-size: 24px;\n  z-index: 1;\n}\n\n.brand-emoji img {\n  width: 32px;\n  height: 32px;\n  border-radius: 8px;\n}\n\n.brand-glow {\n  position: absolute;\n  top: -5px;\n  left: -5px;\n  right: -5px;\n  bottom: -5px;\n  background: radial-gradient(circle, var(--accent) 0%, transparent 70%);\n  opacity: 0.3;\n  border-radius: 50%;\n  animation: pulse 2s infinite;\n}\n\n.brand-text {\n  display: flex;\n  align-items: baseline;\n  gap: 8px;\n}\n\n.brand-name {\n  font-weight: 700;\n  color: var(--text);\n}\n\n.brand-tag {\n  font-size: 12px;\n  font-weight: 600;\n  color: var(--accent);\n  background: rgba(0, 123, 255, 0.1);\n  padding: 2px 8px;\n  border-radius: 10px;\n}\n\n.brand-sep {\n  width: 1px;\n  height: 20px;\n  background: var(--border);\n  margin: 0 12px;\n}\n\n.brand-sub {\n  font-size: 12px;\n  color: var(--text-3);\n  font-weight: 500;\n}\n\n.service-pill {\n  display: flex;\n  align-items: center;\n  gap: 8px;\n  padding: 6px 12px;\n  border-radius: 16px;\n  font-size: 14px;\n  font-weight: 500;\n  background: rgba(52, 199, 89, 0.1);\n  color: var(--success);\n  transition: all 0.3s ease;\n}\n\n.service-pill.service-online {\n  background: rgba(52, 199, 89, 0.1);\n  color: var(--success);\n}\n\n.service-pill.service-offline {\n  background: rgba(255, 59, 48, 0.1);\n  color: var(--danger);\n}\n\n.service-pill.service-unknown {\n  background: rgba(255, 149, 0, 0.1);\n  color: var(--warning);\n}\n\n.service-dot {\n  width: 8px;\n  height: 8px;\n  border-radius: 50%;\n  background: var(--success);\n  animation: pulse 2s infinite;\n}\n\n.service-pill.service-offline .service-dot {\n  background: var(--danger);\n}\n\n.service-pill.service-unknown .service-dot {\n  background: var(--warning);\n}\n\n.service-recheck {\n  background: none;\n  border: none;\n  color: inherit;\n  cursor: pointer;\n  font-size: 14px;\n  padding: 0;\n  width: 20px;\n  height: 20px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  border-radius: 50%;\n  transition: all 0.3s ease;\n}\n\n.service-recheck:hover {\n  background: rgba(255, 255, 255, 0.2);\n}\n\n.service-recheck:disabled {\n  opacity: 0.5;\n  cursor: not-allowed;\n}\n\n@keyframes float {\n  0%, 100% {\n    transform: translate(0, 0) rotate(0deg);\n  }\n  25% {\n    transform: translate(20px, -20px) rotate(5deg);\n  }\n  50% {\n    transform: translate(0, 20px) rotate(0deg);\n  }\n  75% {\n    transform: translate(-20px, -10px) rotate(-5deg);\n  }\n}\n\n@keyframes pulse {\n  0%, 100% {\n    opacity: 1;\n  }\n  50% {\n    opacity: 0.5;\n  }\n}\n</style>"],"mappings":"AA6CA;EACAA,IAAA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}