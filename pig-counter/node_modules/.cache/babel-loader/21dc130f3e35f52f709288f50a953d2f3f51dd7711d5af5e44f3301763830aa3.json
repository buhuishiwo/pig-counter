{"ast":null,"code":"import UploadZone from '@/components/UploadZone.vue';\nimport ResultPanel from '@/components/ResultPanel.vue';\nimport LogPanel from '@/components/LogPanel.vue';\nimport AnalyzeButton from '@/components/AnalyzeButton.vue';\nimport ServiceStatus from '@/components/ServiceStatus.vue';\n\n// ============================================================\n// 切换 Mock / 真实 API：\n//   开发阶段使用 analyzeImageMock\n//   生产环境使用 analyzeImage\n// ============================================================\nimport { analyzeImageMock as analyzeImage, checkHealth } from '@/api/pigModel';\nexport default {\n  name: 'App',\n  components: {\n    UploadZone,\n    ResultPanel,\n    LogPanel,\n    AnalyzeButton,\n    ServiceStatus\n  },\n  data() {\n    return {\n      checkingService: false\n    };\n  },\n  computed: {\n    hasImage() {\n      return this.$store.getters.hasImage;\n    },\n    imageMeta() {\n      return this.$store.state.imageMeta;\n    },\n    isAnalyzing() {\n      return this.$store.state.isAnalyzing;\n    },\n    uploadProgress() {\n      return this.$store.state.uploadProgress;\n    },\n    year() {\n      return new Date().getFullYear();\n    }\n  },\n  created() {\n    this.checkServiceHealth();\n  },\n  methods: {\n    onImageLoaded() {\n      // 图片加载成功，可以在这里做额外处理\n    },\n    onUploadError(msg) {\n      console.error('[Upload Error]', msg);\n    },\n    reupload() {\n      // 借助 UploadZone 内的 input 触发\n      document.querySelector('input[type=\"file\"]').click();\n    },\n    clearImage() {\n      this.$store.commit('CLEAR_IMAGE');\n      this.$store.commit('ADD_LOG', {\n        msg: '已清除图片',\n        type: 'info'\n      });\n    },\n    async runAnalysis() {\n      if (!this.hasImage || this.isAnalyzing) return;\n      this.$store.commit('SET_ANALYZING', true);\n      this.$store.commit('SET_PROGRESS', 0);\n      this.$store.commit('ADD_LOG', {\n        msg: '开始发送至数猪大模型...',\n        type: 'info'\n      });\n      try {\n        const result = await analyzeImage(this.$store.state.imageFile, progress => this.$store.commit('SET_PROGRESS', progress));\n        this.$store.commit('SET_RESULT', result);\n        this.$store.commit('SET_PROGRESS', 100);\n        this.$store.commit('ADD_LOG', {\n          msg: `识别完成：共检测到 ${result.count} 头猪`,\n          type: 'success'\n        });\n        this.$store.commit('ADD_LOG', {\n          msg: `置信度：${Math.round(result.confidence * 100)}%` + (result.inferenceTime ? `  推理耗时：${result.inferenceTime}ms` : ''),\n          type: 'success'\n        });\n      } catch (err) {\n        this.$store.commit('ADD_LOG', {\n          msg: `识别失败：${err.message}`,\n          type: 'error'\n        });\n        console.error('[Analysis Error]', err);\n      } finally {\n        this.$store.commit('SET_ANALYZING', false);\n      }\n    },\n    async checkServiceHealth() {\n      this.checkingService = true;\n      this.$store.commit('ADD_LOG', {\n        msg: '正在检测模型服务状态...',\n        type: 'info'\n      });\n      try {\n        const online = await checkHealth();\n        this.$store.commit('SET_SERVICE_STATUS', online);\n        this.$store.commit('ADD_LOG', {\n          msg: online ? '模型服务在线，可以使用' : '模型服务未响应（使用 Mock 模式）',\n          type: online ? 'success' : 'warn'\n        });\n      } catch {\n        this.$store.commit('SET_SERVICE_STATUS', false);\n      } finally {\n        this.checkingService = false;\n      }\n    }\n  }\n};","map":{"version":3,"names":["UploadZone","ResultPanel","LogPanel","AnalyzeButton","ServiceStatus","analyzeImageMock","analyzeImage","checkHealth","name","components","data","checkingService","computed","hasImage","$store","getters","imageMeta","state","isAnalyzing","uploadProgress","year","Date","getFullYear","created","checkServiceHealth","methods","onImageLoaded","onUploadError","msg","console","error","reupload","document","querySelector","click","clearImage","commit","type","runAnalysis","result","imageFile","progress","count","Math","round","confidence","inferenceTime","err","message","online"],"sources":["src/App.vue"],"sourcesContent":["<template>\n  <div id=\"app\">\n    <!-- Grain overlay -->\n    <div class=\"grain-overlay\" aria-hidden=\"true\"></div>\n\n    <div class=\"container\">\n      <!-- ===== HEADER ===== -->\n      <header class=\"header\">\n        <div class=\"header-badge\">AI Vision · 猪只检测系统</div>\n        <h1 class=\"header-title\">智能数猪大模型</h1>\n        <p class=\"header-sub\">上传猪群图片，AI 自动识别并精准统计数量</p>\n        <div class=\"header-divider\"></div>\n      </header>\n\n      <!-- ===== MAIN CONTENT ===== -->\n      <main class=\"main-grid\">\n\n        <!-- Left: Upload section -->\n        <section class=\"upload-section\">\n          <div class=\"section-card\">\n            <div class=\"card-header\">\n              <span class=\"card-dot\"></span>\n              <span class=\"card-title\">图像输入区域</span>\n              <span v-if=\"imageMeta\" class=\"card-badge\">{{ imageMeta.width }}×{{ imageMeta.height }}</span>\n            </div>\n\n            <div class=\"card-body\">\n              <!-- Upload zone component -->\n              <UploadZone @loaded=\"onImageLoaded\" @error=\"onUploadError\" />\n\n              <!-- Action buttons -->\n              <div class=\"btn-row\" v-if=\"hasImage\">\n                <button class=\"btn-reupload\" @click=\"reupload\">\n                  📁 更换图片\n                </button>\n                <button class=\"btn-clear\" @click=\"clearImage\">\n                  清除\n                </button>\n              </div>\n\n              <!-- Analyze button component -->\n              <AnalyzeButton\n                :progress=\"uploadProgress\"\n                @analyze=\"runAnalysis\"\n                style=\"margin-top: 12px;\"\n              />\n            </div>\n          </div>\n\n          <!-- Tips card -->\n          <div class=\"tips-card\">\n            <div class=\"tips-title\">📌 拍摄建议</div>\n            <ul class=\"tips-list\">\n              <li>使用正面或俯视角度拍摄猪群</li>\n              <li>保证光线充足，避免强烈逆光</li>\n              <li>猪只不应被遮挡超过 50%</li>\n              <li>建议分辨率不低于 640×480</li>\n              <li>置信度低于 60% 时建议重拍</li>\n            </ul>\n          </div>\n        </section>\n\n        <!-- Right: Result & logs -->\n        <aside class=\"result-section\">\n          <!-- Service status -->\n          <ServiceStatus\n            :checking=\"checkingService\"\n            @check=\"checkServiceHealth\"\n          />\n\n          <!-- Result panel -->\n          <ResultPanel />\n\n          <!-- Log panel -->\n          <LogPanel />\n        </aside>\n      </main>\n\n      <!-- ===== FOOTER ===== -->\n      <footer class=\"footer\">\n        <span>智能数猪系统 · Powered by 专属大模型</span>\n        <span class=\"footer-sep\">|</span>\n        <span>© {{ year }} PigVision AI</span>\n      </footer>\n    </div>\n\n    <!-- Loading overlay (full-screen during analysis) -->\n    <transition name=\"fade\">\n      <div class=\"analysis-overlay\" v-if=\"isAnalyzing\">\n        <div class=\"analysis-modal\">\n          <div class=\"modal-spinner\"></div>\n          <div class=\"modal-title\">模型推理中</div>\n          <div class=\"modal-sub\">正在统计猪只数量，请稍候...</div>\n          <div class=\"modal-progress\">\n            <div class=\"modal-progress-fill\" :style=\"{ width: uploadProgress + '%' }\"></div>\n          </div>\n        </div>\n      </div>\n    </transition>\n  </div>\n</template>\n\n<script>\nimport UploadZone     from '@/components/UploadZone.vue'\nimport ResultPanel    from '@/components/ResultPanel.vue'\nimport LogPanel       from '@/components/LogPanel.vue'\nimport AnalyzeButton  from '@/components/AnalyzeButton.vue'\nimport ServiceStatus  from '@/components/ServiceStatus.vue'\n\n// ============================================================\n// 切换 Mock / 真实 API：\n//   开发阶段使用 analyzeImageMock\n//   生产环境使用 analyzeImage\n// ============================================================\nimport { analyzeImageMock as analyzeImage, checkHealth } from '@/api/pigModel'\n\nexport default {\n  name: 'App',\n  components: { UploadZone, ResultPanel, LogPanel, AnalyzeButton, ServiceStatus },\n\n  data() {\n    return {\n      checkingService: false\n    }\n  },\n\n  computed: {\n    hasImage()       { return this.$store.getters.hasImage },\n    imageMeta()      { return this.$store.state.imageMeta },\n    isAnalyzing()    { return this.$store.state.isAnalyzing },\n    uploadProgress() { return this.$store.state.uploadProgress },\n    year()           { return new Date().getFullYear() }\n  },\n\n  created() {\n    this.checkServiceHealth()\n  },\n\n  methods: {\n    onImageLoaded() {\n      // 图片加载成功，可以在这里做额外处理\n    },\n\n    onUploadError(msg) {\n      console.error('[Upload Error]', msg)\n    },\n\n    reupload() {\n      // 借助 UploadZone 内的 input 触发\n      document.querySelector('input[type=\"file\"]').click()\n    },\n\n    clearImage() {\n      this.$store.commit('CLEAR_IMAGE')\n      this.$store.commit('ADD_LOG', { msg: '已清除图片', type: 'info' })\n    },\n\n    async runAnalysis() {\n      if (!this.hasImage || this.isAnalyzing) return\n\n      this.$store.commit('SET_ANALYZING', true)\n      this.$store.commit('SET_PROGRESS', 0)\n      this.$store.commit('ADD_LOG', { msg: '开始发送至数猪大模型...', type: 'info' })\n\n      try {\n        const result = await analyzeImage(\n          this.$store.state.imageFile,\n          progress => this.$store.commit('SET_PROGRESS', progress)\n        )\n\n        this.$store.commit('SET_RESULT', result)\n        this.$store.commit('SET_PROGRESS', 100)\n        this.$store.commit('ADD_LOG', {\n          msg:  `识别完成：共检测到 ${result.count} 头猪`,\n          type: 'success'\n        })\n        this.$store.commit('ADD_LOG', {\n          msg:  `置信度：${Math.round(result.confidence * 100)}%` +\n                (result.inferenceTime ? `  推理耗时：${result.inferenceTime}ms` : ''),\n          type: 'success'\n        })\n      } catch (err) {\n        this.$store.commit('ADD_LOG', { msg: `识别失败：${err.message}`, type: 'error' })\n        console.error('[Analysis Error]', err)\n      } finally {\n        this.$store.commit('SET_ANALYZING', false)\n      }\n    },\n\n    async checkServiceHealth() {\n      this.checkingService = true\n      this.$store.commit('ADD_LOG', { msg: '正在检测模型服务状态...', type: 'info' })\n      try {\n        const online = await checkHealth()\n        this.$store.commit('SET_SERVICE_STATUS', online)\n        this.$store.commit('ADD_LOG', {\n          msg:  online ? '模型服务在线，可以使用' : '模型服务未响应（使用 Mock 模式）',\n          type: online ? 'success' : 'warn'\n        })\n      } catch {\n        this.$store.commit('SET_SERVICE_STATUS', false)\n      } finally {\n        this.checkingService = false\n      }\n    }\n  }\n}\n</script>\n\n<style>\n/* ============================================================\n   CSS 变量 & 全局重置\n   ============================================================ */\n:root {\n  --bg:           #0d0d0d;\n  --surface:      #141414;\n  --card:         #1a1a1a;\n  --border:       #272727;\n  --accent:       #e8c84a;\n  --accent2:      #f4a24a;\n  --text:         #f0ece0;\n  --text-muted:   #706a5a;\n  --pig-pink:     #f2a7b0;\n  --pig-pink-dim: #6a3d44;\n  --success:      #6dcc80;\n  --radius:       16px;\n}\n\n*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\n\nhtml { font-size: 30px; }\n\nbody {\n  background: var(--bg);\n  color: var(--text);\n  font-family: 'Space Mono', 'Courier New', monospace;\n  min-height: 100vh;\n  -webkit-font-smoothing: antialiased;\n}\n\n#app { position: relative; min-height: 100vh; }\n\n/* Grain overlay */\n.grain-overlay {\n  position: fixed;\n  inset: 0;\n  pointer-events: none;\n  z-index: 9999;\n  opacity: 0.5;\n  background-image: url(\"data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.05'/%3E%3C/svg%3E\");\n}\n\n/* ============================================================\n   Layout\n   ============================================================ */\n.container {\n  max-width: 1000px;\n  margin: 0 auto;\n  padding: 20px 24px 80px;\n}\n\n/* ============================================================\n   Header\n   ============================================================ */\n.header {\n  text-align: center;\n  margin-bottom: 50px;\n}\n\n.header-badge {\n  display: inline-block;\n  background: var(--accent);\n  color: #000;\n  font-size: 15px;\n  letter-spacing: 0.22em;\n  text-transform: uppercase;\n  padding: 5px 14px;\n  border-radius: 3px;\n  margin-bottom: 22px;\n  font-weight: 700;\n}\n\n.header-title {\n  font-family: 'Noto Serif SC', serif;\n  font-size: clamp(34px, 6vw, 62px);\n  font-weight: 900;\n  line-height: 1.1;\n  letter-spacing: -0.02em;\n  background: linear-gradient(135deg, var(--text) 0%, var(--pig-pink) 55%, var(--accent2) 100%);\n  -webkit-background-clip: text;\n  -webkit-text-fill-color: transparent;\n  background-clip: text;\n  margin-bottom: 14px;\n}\n\n.header-sub {\n  color: var(--text-muted);\n  font-size: 13px;\n  letter-spacing: 0.05em;\n}\n\n.header-divider {\n  width: 56px;\n  height: 2px;\n  background: linear-gradient(90deg, var(--accent), var(--accent2));\n  border-radius: 1px;\n  margin: 20px auto 0;\n}\n\n/* ============================================================\n   Grid\n   ============================================================ */\n.main-grid {\n  display: grid;\n  grid-template-columns: 1fr 300px;\n  gap: 24px;\n  align-items: start;\n}\n\n@media (max-width: 740px) {\n  .main-grid {\n    grid-template-columns: 1fr;\n  }\n}\n\n/* ============================================================\n   Upload section\n   ============================================================ */\n.upload-section {\n  display: flex;\n  flex-direction: column;\n  gap: 16px;\n}\n\n.section-card {\n  background: var(--card);\n  border: 1.5px solid var(--border);\n  border-radius: var(--radius);\n  overflow: hidden;\n}\n\n.card-header {\n  display: flex;\n  align-items: center;\n  gap: 10px;\n  padding: 16px 22px;\n  border-bottom: 1px solid var(--border);\n}\n\n.card-dot {\n  width: 8px;\n  height: 8px;\n  border-radius: 50%;\n  background: var(--accent);\n  flex-shrink: 0;\n}\n\n.card-title {\n  font-size: 11px;\n  letter-spacing: 0.12em;\n  text-transform: uppercase;\n  color: var(--text-muted);\n  font-weight: 700;\n  flex: 1;\n}\n\n.card-badge {\n  font-size: 10px;\n  color: var(--text-muted);\n  background: var(--surface);\n  border: 1px solid var(--border);\n  border-radius: 4px;\n  padding: 2px 8px;\n  letter-spacing: 0.04em;\n}\n\n.card-body {\n  padding: 24px;\n}\n\n.btn-row {\n  display: flex;\n  gap: 10px;\n  margin-top: 14px;\n}\n\n.btn-reupload {\n  flex: 1;\n  padding: 11px 0;\n  background: var(--accent);\n  color: #000;\n  border: none;\n  border-radius: 8px;\n  font-family: 'Space Mono', monospace;\n  font-size: 12px;\n  font-weight: 700;\n  letter-spacing: 0.06em;\n  cursor: pointer;\n  transition: all 0.18s;\n}\n\n.btn-reupload:hover { background: #f0d55a; transform: translateY(-1px); }\n\n.btn-clear {\n  padding: 11px 16px;\n  background: transparent;\n  color: var(--text-muted);\n  border: 1.5px solid var(--border);\n  border-radius: 8px;\n  font-family: 'Space Mono', monospace;\n  font-size: 12px;\n  cursor: pointer;\n  transition: all 0.18s;\n}\n\n.btn-clear:hover { border-color: var(--pig-pink-dim); color: var(--pig-pink); }\n\n/* Tips */\n.tips-card {\n  background: var(--surface);\n  border: 1px solid var(--border);\n  border-radius: 12px;\n  padding: 18px 20px;\n}\n\n.tips-title {\n  font-size: 11px;\n  letter-spacing: 0.1em;\n  text-transform: uppercase;\n  color: var(--text-muted);\n  margin-bottom: 12px;\n  font-weight: 700;\n}\n\n.tips-list {\n  list-style: none;\n  display: flex;\n  flex-direction: column;\n  gap: 8px;\n}\n\n.tips-list li {\n  font-size: 12px;\n  color: var(--text-muted);\n  line-height: 1.5;\n  padding-left: 14px;\n  position: relative;\n}\n\n.tips-list li::before {\n  content: '›';\n  position: absolute;\n  left: 0;\n  color: var(--accent);\n  font-weight: 700;\n}\n\n/* ============================================================\n   Result section\n   ============================================================ */\n.result-section {\n  display: flex;\n  flex-direction: column;\n  gap: 16px;\n}\n\n/* ============================================================\n   Footer\n   ============================================================ */\n.footer {\n  margin-top: 64px;\n  text-align: center;\n  font-size: 11px;\n  color: var(--border);\n  letter-spacing: 0.08em;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  gap: 10px;\n}\n\n.footer-sep { opacity: 0.4; }\n\n/* ============================================================\n   Analysis overlay\n   ============================================================ */\n.analysis-overlay {\n  position: fixed;\n  inset: 0;\n  background: rgba(0,0,0,0.65);\n  backdrop-filter: blur(8px);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  z-index: 1000;\n}\n\n.analysis-modal {\n  background: var(--card);\n  border: 1.5px solid var(--border);\n  border-radius: 20px;\n  padding: 40px 48px;\n  text-align: center;\n  min-width: 280px;\n}\n\n.modal-spinner {\n  width: 44px;\n  height: 44px;\n  border: 3px solid var(--border);\n  border-top-color: var(--accent);\n  border-radius: 50%;\n  animation: spin 0.7s linear infinite;\n  margin: 0 auto 20px;\n}\n\n@keyframes spin { to { transform: rotate(360deg); } }\n\n.modal-title {\n  font-family: 'Noto Serif SC', serif;\n  font-size: 20px;\n  font-weight: 700;\n  color: var(--text);\n  margin-bottom: 8px;\n}\n\n.modal-sub {\n  font-size: 12px;\n  color: var(--text-muted);\n  letter-spacing: 0.04em;\n  margin-bottom: 20px;\n}\n\n.modal-progress {\n  height: 4px;\n  background: var(--border);\n  border-radius: 2px;\n  overflow: hidden;\n}\n\n.modal-progress-fill {\n  height: 100%;\n  background: linear-gradient(90deg, var(--pig-pink), var(--accent));\n  border-radius: 2px;\n  transition: width 0.3s ease;\n}\n\n/* Fade transition */\n.fade-enter-active, .fade-leave-active { transition: opacity 0.3s; }\n.fade-enter, .fade-leave-to { opacity: 0; }\n</style>\n"],"mappings":"AAuGA,OAAAA,UAAA;AACA,OAAAC,WAAA;AACA,OAAAC,QAAA;AACA,OAAAC,aAAA;AACA,OAAAC,aAAA;;AAEA;AACA;AACA;AACA;AACA;AACA,SAAAC,gBAAA,IAAAC,YAAA,EAAAC,WAAA;AAEA;EACAC,IAAA;EACAC,UAAA;IAAAT,UAAA;IAAAC,WAAA;IAAAC,QAAA;IAAAC,aAAA;IAAAC;EAAA;EAEAM,KAAA;IACA;MACAC,eAAA;IACA;EACA;EAEAC,QAAA;IACAC,SAAA;MAAA,YAAAC,MAAA,CAAAC,OAAA,CAAAF,QAAA;IAAA;IACAG,UAAA;MAAA,YAAAF,MAAA,CAAAG,KAAA,CAAAD,SAAA;IAAA;IACAE,YAAA;MAAA,YAAAJ,MAAA,CAAAG,KAAA,CAAAC,WAAA;IAAA;IACAC,eAAA;MAAA,YAAAL,MAAA,CAAAG,KAAA,CAAAE,cAAA;IAAA;IACAC,KAAA;MAAA,WAAAC,IAAA,GAAAC,WAAA;IAAA;EACA;EAEAC,QAAA;IACA,KAAAC,kBAAA;EACA;EAEAC,OAAA;IACAC,cAAA;MACA;IAAA,CACA;IAEAC,cAAAC,GAAA;MACAC,OAAA,CAAAC,KAAA,mBAAAF,GAAA;IACA;IAEAG,SAAA;MACA;MACAC,QAAA,CAAAC,aAAA,uBAAAC,KAAA;IACA;IAEAC,WAAA;MACA,KAAArB,MAAA,CAAAsB,MAAA;MACA,KAAAtB,MAAA,CAAAsB,MAAA;QAAAR,GAAA;QAAAS,IAAA;MAAA;IACA;IAEA,MAAAC,YAAA;MACA,UAAAzB,QAAA,SAAAK,WAAA;MAEA,KAAAJ,MAAA,CAAAsB,MAAA;MACA,KAAAtB,MAAA,CAAAsB,MAAA;MACA,KAAAtB,MAAA,CAAAsB,MAAA;QAAAR,GAAA;QAAAS,IAAA;MAAA;MAEA;QACA,MAAAE,MAAA,SAAAjC,YAAA,CACA,KAAAQ,MAAA,CAAAG,KAAA,CAAAuB,SAAA,EACAC,QAAA,SAAA3B,MAAA,CAAAsB,MAAA,iBAAAK,QAAA,CACA;QAEA,KAAA3B,MAAA,CAAAsB,MAAA,eAAAG,MAAA;QACA,KAAAzB,MAAA,CAAAsB,MAAA;QACA,KAAAtB,MAAA,CAAAsB,MAAA;UACAR,GAAA,eAAAW,MAAA,CAAAG,KAAA;UACAL,IAAA;QACA;QACA,KAAAvB,MAAA,CAAAsB,MAAA;UACAR,GAAA,SAAAe,IAAA,CAAAC,KAAA,CAAAL,MAAA,CAAAM,UAAA,cACAN,MAAA,CAAAO,aAAA,aAAAP,MAAA,CAAAO,aAAA;UACAT,IAAA;QACA;MACA,SAAAU,GAAA;QACA,KAAAjC,MAAA,CAAAsB,MAAA;UAAAR,GAAA,UAAAmB,GAAA,CAAAC,OAAA;UAAAX,IAAA;QAAA;QACAR,OAAA,CAAAC,KAAA,qBAAAiB,GAAA;MACA;QACA,KAAAjC,MAAA,CAAAsB,MAAA;MACA;IACA;IAEA,MAAAZ,mBAAA;MACA,KAAAb,eAAA;MACA,KAAAG,MAAA,CAAAsB,MAAA;QAAAR,GAAA;QAAAS,IAAA;MAAA;MACA;QACA,MAAAY,MAAA,SAAA1C,WAAA;QACA,KAAAO,MAAA,CAAAsB,MAAA,uBAAAa,MAAA;QACA,KAAAnC,MAAA,CAAAsB,MAAA;UACAR,GAAA,EAAAqB,MAAA;UACAZ,IAAA,EAAAY,MAAA;QACA;MACA;QACA,KAAAnC,MAAA,CAAAsB,MAAA;MACA;QACA,KAAAzB,eAAA;MACA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}