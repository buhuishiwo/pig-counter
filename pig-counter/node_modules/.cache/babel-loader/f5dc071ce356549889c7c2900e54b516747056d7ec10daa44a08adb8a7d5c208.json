{"ast":null,"code":"import \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.map.js\";\nexport default {\n  name: 'ResultPanel',\n  computed: {\n    hasResults() {\n      return this.$store.getters.hasResults;\n    },\n    totalPigs() {\n      return this.$store.getters.totalPigs;\n    },\n    images() {\n      return this.$store.state.images || [];\n    },\n    results() {\n      return this.$store.state.results || {};\n    },\n    imageCount() {\n      return this.results.total_images || 0;\n    },\n    imagesWithResults() {\n      if (!this.hasResults || !this.images.length) return [];\n\n      // 将结果与图片匹配\n      const imageResults = this.results.images || [];\n      return this.images.map((image, index) => {\n        const result = imageResults[index] || {};\n        return {\n          ...image,\n          ...result\n        };\n      });\n    }\n  }\n};","map":{"version":3,"names":["name","computed","hasResults","$store","getters","totalPigs","images","state","results","imageCount","total_images","imagesWithResults","length","imageResults","map","image","index","result"],"sources":["src/components/ResultPanel.vue"],"sourcesContent":["<template>\n  <div class=\"result-panel\" :class=\"{ 'has-result': hasResults }\">\n    <!-- Header -->\n    <div class=\"panel-header\">\n      <span class=\"header-dot\" :class=\"{ active: hasResults }\"></span>\n      <span class=\"header-title\">识别结果</span>\n    </div>\n\n    <!-- Summary -->\n    <div v-if=\"hasResults\" class=\"summary-section\">\n      <div class=\"summary-grid\">\n        <div class=\"summary-item\">\n          <div class=\"summary-label\">上传图片数</div>\n          <div class=\"summary-value\">{{ imageCount }}</div>\n        </div>\n        <div class=\"summary-item\">\n          <div class=\"summary-label\">总猪只数</div>\n          <div class=\"summary-value total-pigs\">{{ totalPigs }}</div>\n        </div>\n      </div>\n    </div>\n\n    <!-- Image results -->\n    <div v-if=\"hasResults\" class=\"image-results\">\n      <div class=\"results-grid\">\n        <div\n          v-for=\"(image, index) in imagesWithResults\"\n          :key=\"index\"\n          class=\"result-image-item\"\n        >\n          <div class=\"image-wrapper\">\n            <img :src=\"image.previewUrl\" class=\"result-image\" alt=\"识别结果\" />\n            <div class=\"pig-count-overlay\">\n              {{ image.predicted_count }} 头\n            </div>\n          </div>\n          <div class=\"result-image-info\">\n            <div class=\"result-image-name\">{{ image.meta.name }}</div>\n            <div class=\"result-image-meta\">\n              <span>{{ image.image_width }}×{{ image.image_height }}</span>\n              <span>{{ image.processing_time_ms }}ms</span>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- Empty state -->\n    <div v-else class=\"empty-state\">\n      <div class=\"empty-icon\">🔍</div>\n      <p>上传图片后点击「开始识别」</p>\n    </div>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'ResultPanel',\n  computed: {\n    hasResults() { return this.$store.getters.hasResults },\n    totalPigs() { return this.$store.getters.totalPigs },\n    images() { return this.$store.state.images || [] },\n    results() { return this.$store.state.results || {} },\n    imageCount() { return this.results.total_images || 0 },\n    \n    imagesWithResults() {\n      if (!this.hasResults || !this.images.length) return []\n      \n      // 将结果与图片匹配\n      const imageResults = this.results.images || []\n      return this.images.map((image, index) => {\n        const result = imageResults[index] || {}\n        return {\n          ...image,\n          ...result\n        }\n      })\n    }\n  }\n}\n</script>\n\n<style scoped>\n.result-panel {\n  background: var(--card);\n  border: 1.5px solid var(--border);\n  border-radius: var(--radius);\n  overflow: hidden;\n  transition: border-color 0.35s;\n}\n\n.result-panel.has-result {\n  border-color: var(--pig-pink-dim);\n}\n\n/* Header */\n.panel-header {\n  display: flex;\n  align-items: center;\n  gap: 10px;\n  padding: 16px 22px;\n  border-bottom: 1px solid var(--border);\n}\n\n.header-dot {\n  width: 8px;\n  height: 8px;\n  border-radius: 50%;\n  background: var(--border);\n  transition: background 0.3s;\n  flex-shrink: 0;\n}\n\n.header-dot.active { background: var(--pig-pink); box-shadow: 0 0 6px var(--pig-pink); }\n\n.header-title {\n  font-size: 11px;\n  letter-spacing: 0.12em;\n  text-transform: uppercase;\n  color: var(--text-muted);\n  font-weight: 700;\n  flex: 1;\n}\n\n/* Summary */\n.summary-section {\n  padding: 20px 22px;\n  border-bottom: 1px solid var(--border);\n}\n\n.summary-grid {\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  gap: 16px;\n}\n\n.summary-item {\n  text-align: center;\n}\n\n.summary-label {\n  font-size: 10px;\n  letter-spacing: 0.12em;\n  text-transform: uppercase;\n  color: var(--text-muted);\n  margin-bottom: 8px;\n}\n\n.summary-value {\n  font-family: 'Noto Serif SC', serif;\n  font-size: 32px;\n  font-weight: 900;\n  color: var(--text);\n  line-height: 1;\n}\n\n.summary-value.total-pigs {\n  background: linear-gradient(135deg, var(--pig-pink), var(--accent2));\n  -webkit-background-clip: text;\n  -webkit-text-fill-color: transparent;\n  background-clip: text;\n}\n\n/* Image results */\n.image-results {\n  padding: 20px 22px;\n  max-height: 400px;\n  overflow-y: auto;\n}\n\n.results-grid {\n  display: grid;\n  grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));\n  gap: 16px;\n}\n\n.result-image-item {\n  border: 1px solid var(--border);\n  border-radius: 8px;\n  overflow: hidden;\n  background: var(--surface);\n  transition: all 0.2s;\n}\n\n.result-image-item:hover {\n  border-color: var(--pig-pink);\n  box-shadow: 0 2px 8px rgba(242, 167, 176, 0.15);\n}\n\n.image-wrapper {\n  position: relative;\n  aspect-ratio: 1;\n  overflow: hidden;\n}\n\n.result-image {\n  width: 100%;\n  height: 100%;\n  object-fit: cover;\n  display: block;\n}\n\n.pig-count-overlay {\n  position: absolute;\n  top: 8px;\n  right: 8px;\n  background: rgba(242, 167, 176, 0.9);\n  color: white;\n  font-size: 12px;\n  font-weight: 700;\n  padding: 4px 8px;\n  border-radius: 4px;\n  backdrop-filter: blur(2px);\n}\n\n.result-image-info {\n  padding: 12px;\n}\n\n.result-image-name {\n  font-size: 12px;\n  font-weight: 500;\n  color: var(--text);\n  margin-bottom: 6px;\n  white-space: nowrap;\n  overflow: hidden;\n  text-overflow: ellipsis;\n}\n\n.result-image-meta {\n  display: flex;\n  justify-content: space-between;\n  font-size: 10px;\n  color: var(--text-muted);\n  font-family: 'Space Mono', monospace;\n}\n\n/* Empty state */\n.empty-state {\n  padding: 32px 22px;\n  text-align: center;\n  color: var(--text-muted);\n  font-size: 12px;\n  line-height: 1.8;\n}\n\n.empty-icon {\n  font-size: 28px;\n  margin-bottom: 10px;\n  opacity: 0.4;\n}\n</style>\n"],"mappings":";;AAwDA;EACAA,IAAA;EACAC,QAAA;IACAC,WAAA;MAAA,YAAAC,MAAA,CAAAC,OAAA,CAAAF,UAAA;IAAA;IACAG,UAAA;MAAA,YAAAF,MAAA,CAAAC,OAAA,CAAAC,SAAA;IAAA;IACAC,OAAA;MAAA,YAAAH,MAAA,CAAAI,KAAA,CAAAD,MAAA;IAAA;IACAE,QAAA;MAAA,YAAAL,MAAA,CAAAI,KAAA,CAAAC,OAAA;IAAA;IACAC,WAAA;MAAA,YAAAD,OAAA,CAAAE,YAAA;IAAA;IAEAC,kBAAA;MACA,UAAAT,UAAA,UAAAI,MAAA,CAAAM,MAAA;;MAEA;MACA,MAAAC,YAAA,QAAAL,OAAA,CAAAF,MAAA;MACA,YAAAA,MAAA,CAAAQ,GAAA,EAAAC,KAAA,EAAAC,KAAA;QACA,MAAAC,MAAA,GAAAJ,YAAA,CAAAG,KAAA;QACA;UACA,GAAAD,KAAA;UACA,GAAAE;QACA;MACA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}