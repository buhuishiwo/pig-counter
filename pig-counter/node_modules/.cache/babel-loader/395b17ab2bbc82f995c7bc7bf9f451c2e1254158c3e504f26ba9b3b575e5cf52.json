{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.for-each.js\";\nimport { validateImage, formatFileSize } from '@/utils/imageUtils';\nexport default {\n  name: 'BatchUploadZone',\n  data() {\n    return {\n      isDragging: false\n    };\n  },\n  computed: {\n    hasBatchFiles() {\n      return this.$store.getters.hasBatchFiles;\n    },\n    batchFileCount() {\n      return this.$store.getters.batchFileCount;\n    },\n    batchFiles() {\n      return this.$store.state.batchFiles;\n    }\n  },\n  methods: {\n    triggerInput() {\n      this.$refs.fileInput.click();\n    },\n    onDragOver() {\n      this.isDragging = true;\n    },\n    onDragLeave() {\n      this.isDragging = false;\n    },\n    onDrop(e) {\n      this.isDragging = false;\n      const files = Array.from(e.dataTransfer.files);\n      if (files.length > 0) this.processFiles(files);\n    },\n    onInputChange(e) {\n      const files = Array.from(e.target.files);\n      if (files.length > 0) this.processFiles(files);\n      this.$refs.fileInput.value = '';\n    },\n    processFiles(files) {\n      const validFiles = [];\n      files.forEach(file => {\n        const {\n          valid,\n          error\n        } = validateImage(file);\n        if (valid) {\n          validFiles.push(file);\n        } else {\n          this.$store.commit('ADD_LOG', {\n            msg: `文件 ${file.name} 无效：${error}`,\n            type: 'error'\n          });\n        }\n      });\n      if (validFiles.length > 0) {\n        this.$store.commit('SET_BATCH_FILES', validFiles);\n        this.$store.commit('ADD_LOG', {\n          msg: `已加载 ${validFiles.length} 个文件`,\n          type: 'info'\n        });\n        this.$emit('filesLoaded', validFiles);\n      }\n    },\n    removeFile(index) {\n      const files = [...this.batchFiles];\n      const removedFile = files.splice(index, 1)[0];\n      this.$store.commit('SET_BATCH_FILES', files);\n      this.$store.commit('ADD_LOG', {\n        msg: `已移除文件：${removedFile.name}`,\n        type: 'info'\n      });\n    },\n    clearFiles() {\n      this.$store.commit('CLEAR_BATCH_FILES');\n      this.$store.commit('ADD_LOG', {\n        msg: '已清空所有文件',\n        type: 'info'\n      });\n    },\n    formatFileSize(size) {\n      return formatFileSize(size);\n    }\n  }\n};","map":{"version":3,"names":["validateImage","formatFileSize","name","data","isDragging","computed","hasBatchFiles","$store","getters","batchFileCount","batchFiles","state","methods","triggerInput","$refs","fileInput","click","onDragOver","onDragLeave","onDrop","e","files","Array","from","dataTransfer","length","processFiles","onInputChange","target","value","validFiles","forEach","file","valid","error","push","commit","msg","type","$emit","removeFile","index","removedFile","splice","clearFiles","size"],"sources":["src/components/BatchUploadZone.vue"],"sourcesContent":["<template>\n  <div\n    class=\"batch-upload-zone\"\n    :class=\"{ 'drag-over': isDragging, 'has-files': hasBatchFiles }\"\n    @dragover.prevent=\"onDragOver\"\n    @dragleave.prevent=\"onDragLeave\"\n    @drop.prevent=\"onDrop\"\n    @click=\"triggerInput\"\n  >\n    <!-- 文件列表 -->\n    <div v-if=\"hasBatchFiles\" class=\"files-list\">\n      <div class=\"files-header\">\n        <h3>待分析文件</h3>\n        <span class=\"file-count\">{{ batchFileCount }} 个文件</span>\n        <button class=\"clear-btn\" @click.stop=\"clearFiles\">\n          <span>清空</span>\n        </button>\n      </div>\n      <div class=\"files-content\">\n        <div\n          v-for=\"(file, index) in batchFiles\"\n          :key=\"index\"\n          class=\"file-item\"\n        >\n          <div class=\"file-icon\">🖼️</div>\n          <div class=\"file-info\">\n            <div class=\"file-name\">{{ file.name }}</div>\n            <div class=\"file-meta\">{{ formatFileSize(file.size) }}</div>\n          </div>\n          <button class=\"remove-btn\" @click.stop=\"removeFile(index)\">\n            ×\n          </button>\n        </div>\n      </div>\n    </div>\n\n    <!-- 占位内容 -->\n    <div v-else class=\"placeholder\">\n      <div class=\"pig-float\">🐷</div>\n      <p class=\"placeholder-title\">拖拽多张图片至此 / 点击上传</p>\n      <p class=\"placeholder-sub\">支持 JPG · PNG · WEBP · BMP &nbsp;|&nbsp; 最大 10MB/张</p>\n      <div class=\"placeholder-hint\">\n        <span class=\"hint-icon\">📷</span>\n        支持同时上传多张图片进行批量分析\n      </div>\n    </div>\n\n    <!-- 拖拽高亮提示 -->\n    <div v-if=\"isDragging\" class=\"drag-mask\">\n      <span>松开以上传 🐽</span>\n    </div>\n\n    <!-- 隐藏 input -->\n    <input\n      ref=\"fileInput\"\n      type=\"file\"\n      accept=\"image/jpeg,image/png,image/webp,image/bmp\"\n      multiple\n      style=\"display:none\"\n      @change=\"onInputChange\"\n    />\n  </div>\n</template>\n\n<script>\nimport { validateImage, formatFileSize } from '@/utils/imageUtils'\n\nexport default {\n  name: 'BatchUploadZone',\n  data() {\n    return {\n      isDragging: false\n    }\n  },\n  computed: {\n    hasBatchFiles() { return this.$store.getters.hasBatchFiles },\n    batchFileCount() { return this.$store.getters.batchFileCount },\n    batchFiles() { return this.$store.state.batchFiles }\n  },\n  methods: {\n    triggerInput() {\n      this.$refs.fileInput.click()\n    },\n    onDragOver()  { this.isDragging = true  },\n    onDragLeave() { this.isDragging = false },\n    onDrop(e) {\n      this.isDragging = false\n      const files = Array.from(e.dataTransfer.files)\n      if (files.length > 0) this.processFiles(files)\n    },\n    onInputChange(e) {\n      const files = Array.from(e.target.files)\n      if (files.length > 0) this.processFiles(files)\n      this.$refs.fileInput.value = ''\n    },\n    processFiles(files) {\n      const validFiles = []\n      \n      files.forEach(file => {\n        const { valid, error } = validateImage(file)\n        if (valid) {\n          validFiles.push(file)\n        } else {\n          this.$store.commit('ADD_LOG', { msg: `文件 ${file.name} 无效：${error}`, type: 'error' })\n        }\n      })\n\n      if (validFiles.length > 0) {\n        this.$store.commit('SET_BATCH_FILES', validFiles)\n        this.$store.commit('ADD_LOG', {\n          msg: `已加载 ${validFiles.length} 个文件`,\n          type: 'info'\n        })\n        this.$emit('filesLoaded', validFiles)\n      }\n    },\n    removeFile(index) {\n      const files = [...this.batchFiles]\n      const removedFile = files.splice(index, 1)[0]\n      this.$store.commit('SET_BATCH_FILES', files)\n      this.$store.commit('ADD_LOG', {\n        msg: `已移除文件：${removedFile.name}`,\n        type: 'info'\n      })\n    },\n    clearFiles() {\n      this.$store.commit('CLEAR_BATCH_FILES')\n      this.$store.commit('ADD_LOG', {\n        msg: '已清空所有文件',\n        type: 'info'\n      })\n    },\n    formatFileSize(size) {\n      return formatFileSize(size)\n    }\n  }\n}\n</script>\n\n<style scoped>\n.batch-upload-zone {\n  width: 100%;\n  min-height: 200px;\n  border: 2px dashed var(--border);\n  border-radius: 12px;\n  position: relative;\n  overflow: hidden;\n  cursor: pointer;\n  background: var(--surface);\n  transition: border-color 0.2s, background 0.2s, box-shadow 0.2s;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n\n.batch-upload-zone:hover:not(.has-files) {\n  border-color: var(--pig-pink);\n  background: rgba(242, 167, 176, 0.04);\n}\n\n.batch-upload-zone.drag-over {\n  border-color: var(--accent);\n  background: rgba(232, 200, 74, 0.06);\n  box-shadow: 0 0 0 4px rgba(232, 200, 74, 0.1);\n}\n\n.batch-upload-zone.has-files {\n  border-style: solid;\n  border-color: var(--border);\n  cursor: default;\n  min-height: 300px;\n}\n\n/* Files List */\n.files-list {\n  width: 100%;\n  height: 100%;\n  padding: 20px;\n  box-sizing: border-box;\n}\n\n.files-header {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  margin-bottom: 16px;\n  padding-bottom: 12px;\n  border-bottom: 1px solid var(--border);\n}\n\n.files-header h3 {\n  font-size: 16px;\n  font-weight: 700;\n  color: var(--text);\n  margin: 0;\n}\n\n.file-count {\n  font-size: 12px;\n  color: var(--text-muted);\n  background: var(--surface);\n  padding: 4px 10px;\n  border-radius: 12px;\n  border: 1px solid var(--border);\n}\n\n.clear-btn {\n  background: var(--surface);\n  border: 1px solid var(--border);\n  border-radius: 6px;\n  padding: 4px 12px;\n  font-size: 12px;\n  color: var(--text-muted);\n  cursor: pointer;\n  transition: all 0.2s;\n}\n\n.clear-btn:hover {\n  background: var(--pig-pink);\n  color: white;\n  border-color: var(--pig-pink);\n}\n\n.files-content {\n  max-height: 400px;\n  overflow-y: auto;\n  display: flex;\n  flex-direction: column;\n  gap: 8px;\n}\n\n.file-item {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n  padding: 12px;\n  background: var(--surface);\n  border: 1px solid var(--border);\n  border-radius: 8px;\n  transition: all 0.2s;\n}\n\n.file-item:hover {\n  border-color: var(--pig-pink);\n  background: rgba(242, 167, 176, 0.04);\n}\n\n.file-icon {\n  font-size: 20px;\n  flex-shrink: 0;\n}\n\n.file-info {\n  flex: 1;\n  min-width: 0;\n}\n\n.file-name {\n  font-size: 14px;\n  font-weight: 500;\n  color: var(--text);\n  margin-bottom: 4px;\n  white-space: nowrap;\n  overflow: hidden;\n  text-overflow: ellipsis;\n}\n\n.file-meta {\n  font-size: 12px;\n  color: var(--text-muted);\n}\n\n.remove-btn {\n  background: none;\n  border: none;\n  font-size: 18px;\n  color: var(--text-muted);\n  cursor: pointer;\n  padding: 4px;\n  border-radius: 4px;\n  transition: all 0.2s;\n  flex-shrink: 0;\n}\n\n.remove-btn:hover {\n  background: var(--pig-pink);\n  color: white;\n}\n\n/* Placeholder */\n.placeholder {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 10px;\n  padding: 32px;\n  text-align: center;\n}\n\n.pig-float {\n  font-size: 56px;\n  animation: float 3s ease-in-out infinite;\n}\n\n@keyframes float {\n  0%, 100% { transform: translateY(0) rotate(-3deg); }\n  50%       { transform: translateY(-10px) rotate(3deg); }\n}\n\n.placeholder-title {\n  font-size: 15px;\n  color: var(--text);\n  font-weight: 700;\n  letter-spacing: 0.02em;\n}\n\n.placeholder-sub {\n  font-size: 11px;\n  color: var(--text-muted);\n  letter-spacing: 0.04em;\n}\n\n.placeholder-hint {\n  margin-top: 6px;\n  display: flex;\n  align-items: center;\n  gap: 6px;\n  font-size: 11px;\n  color: var(--text-muted);\n  background: rgba(255,255,255,0.04);\n  border: 1px solid var(--border);\n  border-radius: 6px;\n  padding: 6px 12px;\n}\n\n.hint-icon { font-size: 14px; }\n\n/* Drag mask */\n.drag-mask {\n  position: absolute;\n  inset: 0;\n  background: rgba(232, 200, 74, 0.12);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  font-size: 18px;\n  font-weight: 700;\n  color: var(--accent);\n  letter-spacing: 0.05em;\n  backdrop-filter: blur(2px);\n}\n\n/* Scrollbar */\n.files-content::-webkit-scrollbar {\n  width: 6px;\n}\n\n.files-content::-webkit-scrollbar-track {\n  background: var(--surface);\n  border-radius: 3px;\n}\n\n.files-content::-webkit-scrollbar-thumb {\n  background: var(--border);\n  border-radius: 3px;\n}\n\n.files-content::-webkit-scrollbar-thumb:hover {\n  background: var(--pig-pink);\n}\n</style>"],"mappings":";;;AAiEA,SAAAA,aAAA,EAAAC,cAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,UAAA;IACA;EACA;EACAC,QAAA;IACAC,cAAA;MAAA,YAAAC,MAAA,CAAAC,OAAA,CAAAF,aAAA;IAAA;IACAG,eAAA;MAAA,YAAAF,MAAA,CAAAC,OAAA,CAAAC,cAAA;IAAA;IACAC,WAAA;MAAA,YAAAH,MAAA,CAAAI,KAAA,CAAAD,UAAA;IAAA;EACA;EACAE,OAAA;IACAC,aAAA;MACA,KAAAC,KAAA,CAAAC,SAAA,CAAAC,KAAA;IACA;IACAC,WAAA;MAAA,KAAAb,UAAA;IAAA;IACAc,YAAA;MAAA,KAAAd,UAAA;IAAA;IACAe,OAAAC,CAAA;MACA,KAAAhB,UAAA;MACA,MAAAiB,KAAA,GAAAC,KAAA,CAAAC,IAAA,CAAAH,CAAA,CAAAI,YAAA,CAAAH,KAAA;MACA,IAAAA,KAAA,CAAAI,MAAA,WAAAC,YAAA,CAAAL,KAAA;IACA;IACAM,cAAAP,CAAA;MACA,MAAAC,KAAA,GAAAC,KAAA,CAAAC,IAAA,CAAAH,CAAA,CAAAQ,MAAA,C