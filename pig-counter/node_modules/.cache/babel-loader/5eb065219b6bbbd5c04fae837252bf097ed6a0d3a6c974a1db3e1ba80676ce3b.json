{"ast":null,"code":"import \"core-js/modules/es.json.stringify.js\";\nimport \"core-js/modules/web.url-search-params.delete.js\";\nimport \"core-js/modules/web.url-search-params.has.js\";\nimport \"core-js/modules/web.url-search-params.size.js\";\nexport default {\n  name: 'BatchResultPanel',\n  computed: {\n    batchResults() {\n      return this.$store.state.batchResults;\n    }\n  },\n  methods: {\n    exportResults() {\n      if (!this.batchResults) return;\n      const data = {\n        exportTime: new Date().toISOString(),\n        totalImages: this.batchResults.total_images,\n        totalPigs: this.batchResults.total_pigs,\n        images: this.batchResults.images\n      };\n      const blob = new Blob([JSON.stringify(data, null, 2)], {\n        type: 'application/json'\n      });\n      const url = URL.createObjectURL(blob);\n      const a = document.createElement('a');\n      a.href = url;\n      a.download = `batch-result-${Date.now()}.json`;\n      document.body.appendChild(a);\n      a.click();\n      document.body.removeChild(a);\n      URL.revokeObjectURL(url);\n      this.$store.commit('ADD_LOG', {\n        msg: '已导出批量分析结果',\n        type: 'info'\n      });\n    },\n    clearResults() {\n      this.$store.commit('CLEAR_BATCH_FILES');\n      this.$store.commit('ADD_LOG', {\n        msg: '已清除批量分析结果',\n        type: 'info'\n      });\n    }\n  }\n};","map":{"version":3,"names":["name","computed","batchResults","$store","state","methods","exportResults","data","exportTime","Date","toISOString","totalImages","total_images","totalPigs","total_pigs","images","blob","Blob","JSON","stringify","type","url","URL","createObjectURL","a","document","createElement","href","download","now","body","appendChild","click","removeChild","revokeObjectURL","commit","msg","clearResults"],"sources":["src/components/BatchResultPanel.vue"],"sourcesContent":["<template>\n  <div v-if=\"batchResults\" class=\"batch-result-panel\">\n    <div class=\"result-header\">\n      <h3>批量分析结果</h3>\n      <div class=\"result-summary\">\n        <div class=\"summary-item\">\n          <span class=\"summary-label\">总图片数</span>\n          <span class=\"summary-value\">{{ batchResults.total_images }}</span>\n        </div>\n        <div class=\"summary-item\">\n          <span class=\"summary-label\">总猪只数</span>\n          <span class=\"summary-value total-pigs\">{{ batchResults.total_pigs }}</span>\n        </div>\n      </div>\n    </div>\n    \n    <div class=\"result-list\">\n      <div\n        v-for=\"(image, index) in batchResults.images\"\n        :key=\"index\"\n        class=\"result-item\"\n      >\n        <div class=\"result-item-header\">\n          <span class=\"result-item-name\">{{ image.filename }}</span>\n          <span class=\"result-item-count\">{{ image.predicted_count }} 头猪</span>\n        </div>\n        <div class=\"result-item-meta\">\n          <span class=\"meta-item\">{{ image.image_width }}×{{ image.image_height }}</span>\n          <span class=\"meta-item\">{{ image.processing_time_ms }}ms</span>\n        </div>\n      </div>\n    </div>\n    \n    <div class=\"result-actions\">\n      <button class=\"action-btn\" @click=\"exportResults\">\n        <span class=\"btn-icon\">📤</span>\n        导出结果\n      </button>\n      <button class=\"action-btn\" @click=\"clearResults\">\n        <span class=\"btn-icon\">🗑️</span>\n        清除结果\n      </button>\n    </div>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'BatchResultPanel',\n  computed: {\n    batchResults() { return this.$store.state.batchResults }\n  },\n  methods: {\n    exportResults() {\n      if (!this.batchResults) return\n\n      const data = {\n        exportTime: new Date().toISOString(),\n        totalImages: this.batchResults.total_images,\n        totalPigs: this.batchResults.total_pigs,\n        images: this.batchResults.images\n      }\n\n      const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' })\n      const url = URL.createObjectURL(blob)\n      const a = document.createElement('a')\n      a.href = url\n      a.download = `batch-result-${Date.now()}.json`\n      document.body.appendChild(a)\n      a.click()\n      document.body.removeChild(a)\n      URL.revokeObjectURL(url)\n\n      this.$store.commit('ADD_LOG', {\n        msg: '已导出批量分析结果',\n        type: 'info'\n      })\n    },\n    clearResults() {\n      this.$store.commit('CLEAR_BATCH_FILES')\n      this.$store.commit('ADD_LOG', {\n        msg: '已清除批量分析结果',\n        type: 'info'\n      })\n    }\n  }\n}\n</script>\n\n<style scoped>\n.batch-result-panel {\n  background: var(--surface);\n  border: 1px solid var(--border);\n  border-radius: 12px;\n  padding: 20px;\n  margin-top: 20px;\n}\n\n.result-header {\n  margin-bottom: 20px;\n  padding-bottom: 16px;\n  border-bottom: 1px solid var(--border);\n}\n\n.result-header h3 {\n  font-size: 16px;\n  font-weight: 700;\n  color: var(--text);\n  margin: 0 0 12px 0;\n}\n\n.result-summary {\n  display: flex;\n  gap: 20px;\n  flex-wrap: wrap;\n}\n\n.summary-item {\n  display: flex;\n  flex-direction: column;\n  gap: 4px;\n}\n\n.summary-label {\n  font-size: 12px;\n  color: var(--text-muted);\n}\n\n.summary-value {\n  font-size: 18px;\n  font-weight: 700;\n  color: var(--text);\n}\n\n.summary-value.total-pigs {\n  color: var(--pig-pink);\n}\n\n.result-list {\n  margin-bottom: 20px;\n  max-height: 400px;\n  overflow-y: auto;\n  display: flex;\n  flex-direction: column;\n  gap: 12px;\n}\n\n.result-item {\n  background: var(--surface);\n  border: 1px solid var(--border);\n  border-radius: 8px;\n  padding: 16px;\n  transition: all 0.2s;\n}\n\n.result-item:hover {\n  border-color: var(--pig-pink);\n  background: rgba(242, 167, 176, 0.04);\n}\n\n.result-item-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  margin-bottom: 8px;\n}\n\n.result-item-name {\n  font-size: 14px;\n  font-weight: 500;\n  color: var(--text);\n  white-space: nowrap;\n  overflow: hidden;\n  text-overflow: ellipsis;\n  flex: 1;\n}\n\n.result-item-count {\n  font-size: 14px;\n  font-weight: 700;\n  color: var(--pig-pink);\n  background: rgba(242, 167, 176, 0.1);\n  padding: 4px 10px;\n  border-radius: 12px;\n}\n\n.result-item-meta {\n  display: flex;\n  gap: 16px;\n  font-size: 12px;\n  color: var(--text-muted);\n}\n\n.meta-item {\n  display: flex;\n  align-items: center;\n  gap: 4px;\n}\n\n.result-actions {\n  display: flex;\n  gap: 12px;\n  justify-content: flex-end;\n  padding-top: 16px;\n  border-top: 1px solid var(--border);\n}\n\n.action-btn {\n  display: flex;\n  align-items: center;\n  gap: 6px;\n  padding: 8px 16px;\n  background: var(--surface);\n  border: 1px solid var(--border);\n  border-radius: 6px;\n  font-size: 12px;\n  color: var(--text);\n  cursor: pointer;\n  transition: all 0.2s;\n}\n\n.action-btn:hover {\n  background: var(--pig-pink);\n  color: white;\n  border-color: var(--pig-pink);\n}\n\n.btn-icon {\n  font-size: 14px;\n}\n\n/* Scrollbar */\n.result-list::-webkit-scrollbar {\n  width: 6px;\n}\n\n.result-list::-webkit-scrollbar-track {\n  background: var(--surface);\n  border-radius: 3px;\n}\n\n.result-list::-webkit-scrollbar-thumb {\n  background: var(--border);\n  border-radius: 3px;\n}\n\n.result-list::-webkit-scrollbar-thumb:hover {\n  background: var(--pig-pink);\n}\n</style>"],"mappings":";;;;AA+CA;EACAA,IAAA;EACAC,QAAA;IACAC,aAAA;MAAA,YAAAC,MAAA,CAAAC,KAAA,CAAAF,YAAA;IAAA;EACA;EACAG,OAAA;IACAC,cAAA;MACA,UAAAJ,YAAA;MAEA,MAAAK,IAAA;QACAC,UAAA,MAAAC,IAAA,GAAAC,WAAA;QACAC,WAAA,OAAAT,YAAA,CAAAU,YAAA;QACAC,SAAA,OAAAX,YAAA,CAAAY,UAAA;QACAC,MAAA,OAAAb,YAAA,CAAAa;MACA;MAEA,MAAAC,IAAA,OAAAC,IAAA,EAAAC,IAAA,CAAAC,SAAA,CAAAZ,IAAA;QAAAa,IAAA;MAAA;MACA,MAAAC,GAAA,GAAAC,GAAA,CAAAC,eAAA,CAAAP,IAAA;MACA,MAAAQ,CAAA,GAAAC,QAAA,CAAAC,aAAA;MACAF,CAAA,CAAAG,IAAA,GAAAN,GAAA;MACAG,CAAA,CAAAI,QAAA,mBAAAnB,IAAA,CAAAoB,GAAA;MACAJ,QAAA,CAAAK,IAAA,CAAAC,WAAA,CAAAP,CAAA;MACAA,CAAA,CAAAQ,KAAA;MACAP,QAAA,CAAAK,IAAA,CAAAG,WAAA,CAAAT,CAAA;MACA