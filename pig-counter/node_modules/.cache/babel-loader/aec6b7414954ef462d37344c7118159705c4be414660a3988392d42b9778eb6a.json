{"ast":null,"code":"import \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.for-each.js\";\nexport default {\n  data() {\n    return {\n      energyActive: false\n    };\n  },\n  mounted() {\n    this.initHUDGlow();\n  },\n  methods: {\n    /* 鼠标跟随光 */\n    initHUDGlow() {\n      const els = document.querySelectorAll('.hud-glow');\n      els.forEach(el => {\n        el.addEventListener('mousemove', e => {\n          const rect = el.getBoundingClientRect();\n          el.style.setProperty('--mx', `${e.clientX - rect.left}px`);\n          el.style.setProperty('--my', `${e.clientY - rect.top}px`);\n        });\n      });\n    },\n    /* 模拟识别完成 */\n    mockFinish() {\n      this.energyActive = false;\n      this.$nextTick(() => {\n        this.energyActive = true;\n        setTimeout(() => {\n          this.energyActive = false;\n        }, 1200);\n      });\n    }\n  }\n};","map":{"version":3,"names":["data","energyActive","mounted","initHUDGlow","methods","els","document","querySelectorAll","forEach","el","addEventListener","e","rect","getBoundingClientRect","style","setProperty","clientX","left","clientY","top","mockFinish","$nextTick","setTimeout"],"sources":["src/App.vue"],"sourcesContent":["<template>\n  <div id=\"app\">\n    <div class=\"grain-overlay\" aria-hidden=\"true\"></div>\n\n    <nav class=\"topbar\">\n      <div class=\"topbar-inner\">\n        <div class=\"topbar-brand\">\n          <span class=\"brand-icon\">🐷</span>\n          <span class=\"brand-name\">AI 智能数猪平台</span>\n          <span class=\"brand-ver\">v0.1</span>\n        </div>\n\n        <div class=\"topbar-actions\">\n          <button class=\"btn-analyze-mini\" @click=\"mockFinish\">\n            模拟识别完成\n          </button>\n        </div>\n      </div>\n    </nav>\n\n    <div class=\"page-wrap\">\n\n      <!-- ===== STAT CARDS ===== -->\n      <div class=\"stat-row\">\n        <div class=\"stat-card hud-glow\" :class=\"{ 'energy-active': energyActive }\">\n          <div class=\"hud-scan\"></div>\n          <div class=\"energy-wave\"></div>\n\n          <div class=\"stat-icon\">🐷</div>\n          <div class=\"stat-val\">12</div>\n          <div class=\"stat-label\">预测数量</div>\n        </div>\n\n        <div class=\"stat-card hud-glow\" :class=\"{ 'energy-active': energyActive }\">\n          <div class=\"hud-scan\"></div>\n          <div class=\"energy-wave\"></div>\n\n          <div class=\"stat-icon\">⚡</div>\n          <div class=\"stat-val\">132</div>\n          <div class=\"stat-label\">耗时 ms</div>\n        </div>\n      </div>\n\n      <!-- ===== IMAGE CARD ===== -->\n      <div class=\"img-card hud-glow\" :class=\"{ 'energy-active': energyActive }\">\n        <div class=\"hud-scan\"></div>\n        <div class=\"energy-wave\"></div>\n\n        <div class=\"img-card-body\">\n          <div class=\"img-placeholder\">结果区域</div>\n        </div>\n      </div>\n\n    </div>\n  </div>\n</template>\n\n<script>\nexport default {\n  data() {\n    return {\n      energyActive: false\n    }\n  },\n\n  mounted() {\n    this.initHUDGlow()\n  },\n\n  methods: {\n\n    /* 鼠标跟随光 */\n    initHUDGlow() {\n      const els = document.querySelectorAll('.hud-glow')\n      els.forEach(el => {\n        el.addEventListener('mousemove', e => {\n          const rect = el.getBoundingClientRect()\n          el.style.setProperty('--mx', `${e.clientX - rect.left}px`)\n          el.style.setProperty('--my', `${e.clientY - rect.top}px`)\n        })\n      })\n    },\n\n    /* 模拟识别完成 */\n    mockFinish() {\n      this.energyActive = false\n\n      this.$nextTick(() => {\n        this.energyActive = true\n\n        setTimeout(() => {\n          this.energyActive = false\n        }, 1200)\n      })\n    }\n  }\n}\n</script>\n\n<style>\n:root {\n  --bg: #f5f7fb;\n  --card: rgba(255,255,255,0.6);\n  --border: #e6e9f0;\n  --text: #1c1f26;\n}\n\n/* ===== 背景 ===== */\nbody {\n  background: radial-gradient(circle at 20% 10%, #ffffff, #eef2f8 60%, #e9edf5);\n  font-family: monospace;\n}\n\n/* ===== 布局 ===== */\n.page-wrap {\n  padding: 40px;\n}\n\n.stat-row {\n  display: flex;\n  gap: 20px;\n}\n\n.stat-card, .img-card {\n  position: relative;\n  padding: 20px;\n  border-radius: 14px;\n  background: var(--card);\n  backdrop-filter: blur(12px);\n  border: 1px solid rgba(255,255,255,0.6);\n  box-shadow: 0 4px 20px rgba(0,0,0,0.04);\n  overflow: hidden;\n}\n\n/* ===== HUD 光 ===== */\n.hud-glow::before {\n  content: \"\";\n  position: absolute;\n  inset: -20px;\n  border-radius: inherit;\n  background: radial-gradient(\n    320px circle at var(--mx, 50%) var(--my, 50%),\n    rgba(120,160,255,0.12),\n    rgba(160,140,255,0.08),\n    transparent 75%\n  );\n  filter: blur(25px);\n  opacity: 0;\n  transition: 0.4s;\n}\n\n.hud-glow:hover::before {\n  opacity: 1;\n}\n\n/* ===== 扫描雾 ===== */\n.hud-scan::before {\n  content: \"\";\n  position: absolute;\n  inset: -50%;\n  background: radial-gradient(\n    circle,\n    rgba(120,160,255,0.08),\n    transparent 60%\n  );\n  filter: blur(35px);\n  animation: float 10s infinite;\n  opacity: 0;\n}\n\n.hud-glow:hover .hud-scan::before {\n  opacity: 1;\n}\n\n@keyframes float {\n  50% { transform: translate(10%,10%) scale(1.2); }\n}\n\n/* =======================================================\n   🌊 能量波（核心）\n   ======================================================= */\n\n.energy-wave {\n  position: absolute;\n  inset: 0;\n  pointer-events: none;\n  overflow: hidden;\n  border-radius: inherit;\n}\n\n/* 波纹 */\n.energy-wave::before {\n  content: \"\";\n  position: absolute;\n  top: 50%;\n  left: 50%;\n  width: 20px;\n  height: 20px;\n  border-radius: 50%;\n  transform: translate(-50%, -50%) scale(0);\n\n  background: radial-gradient(\n    circle,\n    rgba(120,160,255,0.25),\n    rgba(160,140,255,0.15),\n    transparent 70%\n  );\n\n  filter: blur(10px);\n  opacity: 0;\n}\n\n/* 激活动画 */\n.energy-active .energy-wave::before {\n  animation: energyPulse 1.2s ease-out forwards;\n}\n\n@keyframes energyPulse {\n  0% {\n    transform: translate(-50%, -50%) scale(0.2);\n    opacity: 0.4;\n  }\n  60% {\n    opacity: 0.2;\n  }\n  100% {\n    transform: translate(-50%, -50%) scale(8);\n    opacity: 0;\n  }\n}\n\n/* ===== 文本 ===== */\n.stat-val {\n  font-size: 28px;\n  font-weight: bold;\n}\n\n.stat-label {\n  font-size: 12px;\n  color: #8a90a2;\n}\n\n/* ===== 按钮 ===== */\n.btn-analyze-mini {\n  background: linear-gradient(135deg,#7aa2ff,#a18cff);\n  color:#fff;\n  padding:8px 16px;\n  border-radius:8px;\n  border:none;\n  cursor:pointer;\n}\n</style>"],"mappings":";;AA0DA;EACAA,KAAA;IACA;MACAC,YAAA;IACA;EACA;EAEAC,QAAA;IACA,KAAAC,WAAA;EACA;EAEAC,OAAA;IAEA;IACAD,YAAA;MACA,MAAAE,GAAA,GAAAC,QAAA,CAAAC,gBAAA;MACAF,GAAA,CAAAG,OAAA,CAAAC,EAAA;QACAA,EAAA,CAAAC,gBAAA,cAAAC,CAAA;UACA,MAAAC,IAAA,GAAAH,EAAA,CAAAI,qBAAA;UACAJ,EAAA,CAAAK,KAAA,CAAAC,WAAA,YAAAJ,CAAA,CAAAK,OAAA,GAAAJ,IAAA,CAAAK,IAAA;UACAR,EAAA,CAAAK,KAAA,CAAAC,WAAA,YAAAJ,CAAA,CAAAO,OAAA,GAAAN,IAAA,CAAAO,GAAA;QACA;MACA;IACA;IAEA;IACAC,WAAA;MACA,KAAAnB,YAAA;MAEA,KAAAoB,SAAA;QACA,KAAApB,YAAA;QAEAqB,UAAA;UACA,KAAArB,YAAA;QACA;MACA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}